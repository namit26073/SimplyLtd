---
/**
 * Interactive map of Paddington Basin via Leaflet + OpenStreetMap tiles.
 * No API key, no billing, no Google branding. Two pitch markers:
 *   - Merchant Square (W2 1PW) — Falafel + Shawarma
 *   - Canal Side Walk (W2 1AS) — Burgers
 *
 * Coordinates from CLAUDE.md owner-confirmed pitches (2026-05-16).
 */
---

<div class="basin-map">
  <div
    id="basin-map"
    class="basin-map__canvas"
    role="application"
    aria-label="Paddington Basin pitch map — two Simply Ltd locations marked"
  ></div>
  <p class="basin-map__caption t-caption">
    Two pitches on Paddington Basin, about 250 metres apart.
  </p>
</div>

<style>
  .basin-map {
    width: 100%;
  }
  .basin-map__canvas {
    width: 100%;
    aspect-ratio: 16 / 9;
    max-height: 560px;
    border-radius: var(--r-lg);
    overflow: hidden;
    background: var(--color-paper);
    border: 1px solid var(--color-line);
  }
  @media (min-width: 900px) {
    .basin-map__canvas {
      aspect-ratio: 16 / 8;
    }
  }
  .basin-map__caption {
    margin-top: var(--sp-3);
    color: var(--color-text-muted);
  }

  /* Brand-coloured pin styles via Leaflet's divIcon. */
  :global(.basin-pin) {
    background: var(--color-ink);
    color: var(--color-cream);
    font-family: var(--ff-body-stack);
    font-weight: var(--fw-strong);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: var(--sp-1) var(--sp-3);
    border-radius: var(--r-pill);
    border: 2px solid var(--color-cream);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.25);
    white-space: nowrap;
    transform: translate(-50%, -100%);
  }
  :global(.basin-pin--green) {
    background: #3f7a3a;
  }
  :global(.basin-pin--red) {
    background: #c03020;
  }

  /* Leaflet popup overrides to match brand. */
  :global(.leaflet-popup-content-wrapper) {
    border-radius: var(--r-md);
    padding: var(--sp-1);
  }
  :global(.leaflet-popup-content) {
    margin: var(--sp-3);
    font-family: var(--ff-body-stack);
    font-size: var(--fs-300);
  }
  :global(.leaflet-popup-content strong) {
    font-family: var(--ff-display-stack);
    font-weight: var(--fw-display);
    font-size: var(--fs-400);
    text-transform: uppercase;
    letter-spacing: var(--ls-display-tight);
    display: block;
    margin-bottom: var(--sp-1);
  }
</style>

<script>
  import L from "leaflet";

  const container = document.getElementById("basin-map");
  if (container) {
    const map = L.map(container, {
      center: [51.51895, -0.1758],
      zoom: 17,
      scrollWheelZoom: false,
      zoomControl: true,
      attributionControl: true,
    });

    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      attribution:
        '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      maxZoom: 19,
    }).addTo(map);

    const pins: Array<{
      lat: number;
      lng: number;
      label: string;
      className: string;
      popup: string;
    }> = [
      {
        lat: 51.5193,
        lng: -0.1768,
        label: "Merchant Square",
        className: "basin-pin basin-pin--green",
        popup:
          "<strong>Merchant Square</strong>Simply Falafel + Simply Shawarma<br/>W2 1PW",
      },
      {
        lat: 51.5187,
        lng: -0.1748,
        label: "Canal Side Walk",
        className: "basin-pin basin-pin--red",
        popup: "<strong>Canal Side Walk</strong>Simply Burgers<br/>W2 1AS",
      },
    ];

    for (const p of pins) {
      const icon = L.divIcon({
        className: "",
        html: `<span class="${p.className}">${p.label}</span>`,
        iconSize: [0, 0],
        iconAnchor: [0, 0],
      });
      L.marker([p.lat, p.lng], { icon }).addTo(map).bindPopup(p.popup);
    }
  }
</script>
