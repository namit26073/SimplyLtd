---
/**
 * Homepage hero — full-bleed cinematic background (video by default,
 * static photo on reduced-motion / load failure), type overlaid on a
 * darkened gradient mask. Owner-provided Falafel kitchen footage is the
 * v1 placeholder; future commissioned brand film swaps via the <video>
 * source attribute.
 *
 * Contrast: type lives over the bottom 50% of the hero where the mask
 * is darkest (>70% black). Cream-coloured display type maintains
 * AAA contrast against the masked photo/video.
 *
 * Perf debt logged in PLACEHOLDERS.md: source MP4 is 5.7 MB pre-encode.
 * Target post-cutover: H.264 sub-2 MB + WebM sub-1.5 MB via ffmpeg.
 */

import { Image } from "astro:assets";
import homeHeroPoster from "../assets/placeholders/home-hero.jpg";
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero__bg" aria-hidden="true">
    <Image
      src={homeHeroPoster}
      alt=""
      class="hero__poster"
      widths={[640, 1024, 1440, 1920, 2400]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      quality={75}
    />
    <video
      class="hero__video"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster=""
    >
      <source src="/videos/falafel-truck.mp4" type="video/mp4" />
    </video>
    <div class="hero__mask"></div>
  </div>

  <div class="hero__content">
    <p class="t-caption hero__kicker">Paddington Basin · Since 2019</p>

    <h1 id="hero-heading" class="t-display hero__heading">
      <span class="hero__heading-line">Street food</span>
      <span class="hero__heading-line hero__heading-line--accent">that earned</span>
      <span class="hero__heading-line">its corner of the canal.</span>
    </h1>

    <p class="t-editorial t-editorial--italic hero__dek">
      From a single falafel truck in 2019 to a fleet on Paddington Basin — fresh, fast, and on
      the canal every day.
    </p>

    <div class="hero__ctas">
      <a href="/catering/" class="hero__cta hero__cta--primary">
        Hire us for your event
        <span class="hero__cta-arrow" aria-hidden="true">→</span>
      </a>
      <a href="/locations/" class="hero__cta hero__cta--secondary">Find a truck</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    /* Solid dark ground so the section never flashes white pre-paint */
    background: var(--color-ink);
    min-height: 88vh;
    color: var(--color-cream);
    display: flex;
    align-items: flex-end;
  }

  @media (min-width: 900px) {
    .hero {
      min-height: 92vh;
      align-items: center;
    }
  }

  /* Full-bleed background — poster (LCP image), video on top, mask above both */
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__poster,
  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  .hero__poster {
    z-index: 0;
  }

  .hero__video {
    z-index: 1;
    /* Fade up softly once the video has buffered enough to play. The browser
       paints the poster underneath instantly, so the swap is seamless. */
    opacity: 0;
    transition: opacity var(--dur-slow) var(--ease-out);
  }

  /* When the video can play (or already is playing), reveal it. */
  .hero__video[data-ready] {
    opacity: 1;
  }

  /* Gradient mask — keeps the bottom 60% dark enough for type legibility */
  .hero__mask {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--color-ink) 30%, transparent) 0%,
        color-mix(in srgb, var(--color-ink) 45%, transparent) 40%,
        color-mix(in srgb, var(--color-ink) 78%, transparent) 80%,
        color-mix(in srgb, var(--color-ink) 90%, transparent) 100%
      );
  }

  @media (min-width: 900px) {
    /* Desktop: keep the dark anchor on the left where the type sits */
    .hero__mask {
      background:
        linear-gradient(
          100deg,
          color-mix(in srgb, var(--color-ink) 88%, transparent) 0%,
          color-mix(in srgb, var(--color-ink) 64%, transparent) 40%,
          color-mix(in srgb, var(--color-ink) 18%, transparent) 80%,
          transparent 100%
        );
    }
  }

  /* Type column */
  .hero__content {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: var(--page-max);
    margin: 0 auto;
    padding: var(--sp-7) var(--page-gutter) var(--sp-6);
  }

  @media (min-width: 900px) {
    .hero__content {
      padding: var(--sp-7) var(--page-gutter);
    }
    .hero__content > * {
      max-width: 22ch;
    }
    .hero__dek { max-width: 38ch; }
    .hero__ctas { max-width: none; }
  }

  .hero__kicker {
    color: color-mix(in srgb, var(--color-cream) 75%, transparent);
    margin-bottom: var(--sp-3);
  }

  .hero__heading {
    font-size: clamp(var(--fs-700), 8vw, var(--fs-900));
    line-height: 0.92;
    letter-spacing: var(--ls-display-tight);
    margin-bottom: var(--sp-4);
    color: var(--color-cream);
  }

  .hero__heading-line {
    display: block;
  }

  .hero__heading-line--accent {
    /* Warm amber accent reads against the dark mask and complements the
       falafel/shawarma brand palette. */
    color: #e8b83a;
  }

  /* Staggered reveal */
  .hero__heading-line {
    letter-spacing: var(--ls-display-loose);
    opacity: 0;
    transform: translateY(8px);
    animation: hero-line-in var(--dur-slow) var(--ease-out) forwards;
  }

  .hero__heading-line:nth-child(1) { animation-delay: 200ms; }
  .hero__heading-line:nth-child(2) { animation-delay: 340ms; }
  .hero__heading-line:nth-child(3) { animation-delay: 480ms; }

  @keyframes hero-line-in {
    to {
      letter-spacing: var(--ls-display-tight);
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero__dek {
    font-size: var(--fs-400);
    color: color-mix(in srgb, var(--color-cream) 90%, transparent);
    opacity: 0;
    animation: fade-up var(--dur-base) var(--ease-out) 680ms forwards;
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero__ctas {
    margin-top: var(--sp-5);
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    opacity: 0;
    animation: fade-up var(--dur-base) var(--ease-out) 840ms forwards;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-3) var(--sp-4);
    font-family: var(--ff-body-stack);
    font-weight: var(--fw-strong);
    font-size: var(--fs-200);
    text-transform: uppercase;
    letter-spacing: var(--ls-caption);
    text-decoration: none;
    border-radius: var(--r-pill);
    transition: transform var(--dur-fast) var(--ease-out),
                background var(--dur-fast) var(--ease-out);
  }

  .hero__cta--primary {
    background: var(--color-cream);
    color: var(--color-ink);
  }

  .hero__cta--primary:hover,
  .hero__cta--primary:focus-visible {
    transform: translateY(-1px);
    background: #fff;
  }

  .hero__cta--secondary {
    background: transparent;
    color: var(--color-cream);
    border: 1.5px solid var(--color-cream);
  }

  .hero__cta--secondary:hover,
  .hero__cta--secondary:focus-visible {
    background: var(--color-cream);
    color: var(--color-ink);
  }

  .hero__cta-arrow {
    transition: transform var(--dur-fast) var(--ease-out);
  }

  .hero__cta:hover .hero__cta-arrow,
  .hero__cta:focus-visible .hero__cta-arrow {
    transform: translateX(3px);
  }

  /* Focus outlines on the cream-on-dark hero */
  .hero :focus-visible {
    outline: 2px solid var(--color-cream);
    outline-offset: 3px;
  }

  /* Reduced motion: hide the video, leave the poster as a permanent still.
     The hero still reads as a full-bleed cinematic photo with type overlay. */
  @media (prefers-reduced-motion: reduce) {
    .hero__video { display: none; }
    .hero__heading-line,
    .hero__dek,
    .hero__ctas {
      animation: none;
      opacity: 1;
      transform: none;
      letter-spacing: var(--ls-display-tight);
    }
  }
</style>

<script>
  // Reveal the video once it has at least one playable frame buffered.
  // The poster stays visible underneath, so the transition is seamless.
  const video = document.querySelector(".hero__video");
  if (video instanceof HTMLVideoElement) {
    const ready = () => video.setAttribute("data-ready", "");
    if (video.readyState >= 2) {
      ready();
    } else {
      video.addEventListener("loadeddata", ready, { once: true });
      video.addEventListener("playing", ready, { once: true });
    }
  }
</script>
