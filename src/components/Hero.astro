---
/**
 * Homepage hero — type-led, with a free-floating cutout zone (not a boxed
 * image slot). The cutout placeholder is a soft positioned shape; when the
 * real PNG lands, swap the shape for an <Image /> tag in the same zone.
 */
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero__inner">
    <div class="hero__copy">
      <p class="t-caption hero__kicker">Paddington Basin · Since 2019</p>

      <h1 id="hero-heading" class="t-display hero__heading">
        <span class="hero__heading-line">Street food</span>
        <span class="hero__heading-line hero__heading-line--accent">that earned</span>
        <span class="hero__heading-line">its corner of the canal.</span>
      </h1>

      <p class="t-editorial t-editorial--italic hero__dek">
        From a single falafel truck in 2019 to a fleet on Paddington Basin — fresh, fast, and on
        the canal every day.
      </p>

      <div class="hero__ctas">
        <a href="/catering/" class="hero__cta hero__cta--primary">
          Hire us for your event
          <span class="hero__cta-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/locations/" class="hero__cta hero__cta--secondary">Find a truck</a>
      </div>
    </div>

    {/* Free-floating cutout zone. The shape placeholders below stand in for
        the eventual food PNGs — sized and positioned to suggest the final
        composition. When real cutouts arrive: drop the .hero__shape elements,
        add <Image src={...} class="hero__cutout hero__cutout--main" /> etc. */}
    <div class="hero__art" aria-hidden="true">
      <span class="hero__shape hero__shape--main"></span>
      <span class="hero__shape hero__shape--accent"></span>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: var(--sp-6) var(--page-gutter) var(--sp-7);
    background: var(--color-cream);
    overflow: hidden; /* shapes may bleed off the right edge */
  }

  .hero__inner {
    max-width: var(--page-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-5);
    position: relative;
  }

  @media (min-width: 900px) {
    .hero {
      padding: var(--sp-7) var(--page-gutter) var(--sp-8);
    }
    .hero__inner {
      grid-template-columns: 1.15fr 1fr;
      gap: var(--sp-6);
      align-items: center;
      min-height: 62vh;
    }
  }

  .hero__copy {
    position: relative;
    z-index: 1;
  }

  .hero__kicker {
    color: var(--color-text-muted);
    margin-bottom: var(--sp-4);
  }

  .hero__heading {
    font-size: clamp(var(--fs-700), 9vw, var(--fs-800));
    line-height: 0.96;
    letter-spacing: var(--ls-display-tight);
    margin-bottom: var(--sp-4);
  }

  .hero__heading-line {
    display: block;
  }

  .hero__heading-line--accent {
    /* Deep canal-green — passes AA on cream (~6.4:1) where the original
       `--color-canal` grey was ~3.6:1 and read as "disabled" text. */
    color: #3a5d3f;
  }

  /* Hero load animation: letter-spacing tightens, lines reveal */
  .hero__heading-line {
    letter-spacing: var(--ls-display-loose);
    opacity: 0;
    transform: translateY(8px);
    animation: hero-line-in var(--dur-slow) var(--ease-out) forwards;
  }

  .hero__heading-line:nth-child(1) { animation-delay: 80ms; }
  .hero__heading-line:nth-child(2) { animation-delay: 220ms; }
  .hero__heading-line:nth-child(3) { animation-delay: 360ms; }

  @keyframes hero-line-in {
    to {
      letter-spacing: var(--ls-display-tight);
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero__dek {
    font-size: var(--fs-400);
    max-width: 38ch;
    color: color-mix(in srgb, var(--color-ink) 80%, transparent);
    opacity: 0;
    animation: fade-up var(--dur-base) var(--ease-out) 560ms forwards;
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero__ctas {
    margin-top: var(--sp-5);
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    opacity: 0;
    animation: fade-up var(--dur-base) var(--ease-out) 720ms forwards;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-3) var(--sp-4);
    font-family: var(--ff-body-stack);
    font-weight: var(--fw-strong);
    font-size: var(--fs-200);
    text-transform: uppercase;
    letter-spacing: var(--ls-caption);
    text-decoration: none;
    border-radius: var(--r-pill);
    transition: transform var(--dur-fast) var(--ease-out),
                background var(--dur-fast) var(--ease-out);
  }

  .hero__cta--primary {
    background: var(--color-ink);
    color: var(--color-cream);
  }

  .hero__cta--primary:hover,
  .hero__cta--primary:focus-visible {
    transform: translateY(-1px);
    background: color-mix(in srgb, var(--color-ink) 88%, var(--color-canal));
  }

  .hero__cta--secondary {
    background: transparent;
    color: var(--color-ink);
    border: 1.5px solid var(--color-ink);
  }

  .hero__cta--secondary:hover,
  .hero__cta--secondary:focus-visible {
    background: var(--color-ink);
    color: var(--color-cream);
  }

  .hero__cta-arrow {
    transition: transform var(--dur-fast) var(--ease-out);
  }

  .hero__cta:hover .hero__cta-arrow,
  .hero__cta:focus-visible .hero__cta-arrow {
    transform: translateX(3px);
  }

  /* Cutout zone — no border-radius, no card, no labelled rectangle. The
     shapes below are positioned absolutely; when an <Image /> replaces them
     it inherits the same anchor points. Hidden on mobile: the shape becomes
     a parked blob with no room to "float," and the type-led hero stands on
     its own. When a real cutout PNG arrives it can be placed inline with a
     deliberate mobile size. */
  .hero__art {
    display: none;
  }

  @media (min-width: 900px) {
    .hero__art {
      display: block;
      position: relative;
      height: 100%;
    }
  }

  .hero__shape {
    position: absolute;
    display: block;
    pointer-events: none;
    border-radius: 50%;
    opacity: 0;
    animation: fade-up var(--dur-slow) var(--ease-out) 880ms forwards;
  }

  /* Main shape — the food-cutout zone. Sized to dominate the column;
     bleeds slightly off the right edge to break the grid. */
  .hero__shape--main {
    width: clamp(280px, 56vw, 560px);
    aspect-ratio: 1;
    right: -8%;
    top: 50%;
    transform: translateY(-50%);
    background:
      radial-gradient(
        ellipse at 45% 45%,
        color-mix(in srgb, #3f7a3a 22%, transparent) 0%,
        color-mix(in srgb, #3f7a3a 12%, transparent) 45%,
        transparent 72%
      );
  }

  /* Accent shape — a smaller "side item" hint, off-axis. */
  .hero__shape--accent {
    width: clamp(110px, 22vw, 200px);
    aspect-ratio: 1;
    right: 38%;
    bottom: 6%;
    background:
      radial-gradient(
        ellipse at 50% 50%,
        color-mix(in srgb, #e8b83a 26%, transparent) 0%,
        color-mix(in srgb, #e8b83a 14%, transparent) 50%,
        transparent 75%
      );
    animation-delay: 1040ms;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__heading-line,
    .hero__dek,
    .hero__ctas,
    .hero__shape {
      animation: none;
      opacity: 1;
      transform: none;
      letter-spacing: var(--ls-display-tight);
    }
    .hero__shape--main { transform: translateY(-50%); }
  }
</style>
