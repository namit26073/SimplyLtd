---
/**
 * Homepage hero — type-led composition. Cutout food image slot is reserved
 * via the .hero__image-slot block; when Namit's home-hero asset lands, swap
 * the placeholder for the <Image /> tag.
 */
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero__inner">
    <div class="hero__copy">
      <p class="t-caption hero__kicker">Paddington Basin · Since 2019</p>

      <h1 id="hero-heading" class="t-display hero__heading">
        <span class="hero__heading-line">Street food</span>
        <span class="hero__heading-line hero__heading-line--accent">that earned</span>
        <span class="hero__heading-line">its corner of the canal.</span>
      </h1>

      <p class="t-editorial t-editorial--italic hero__dek">
        From a single falafel truck in 2019 to a fleet on Paddington Basin — fresh, fast, and on
        the canal every day.
      </p>

      <div class="hero__ctas">
        <a href="/catering/" class="hero__cta hero__cta--primary">
          Hire us for your event
          <span class="hero__cta-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/locations/" class="hero__cta hero__cta--secondary">Find a truck</a>
      </div>
    </div>

    <div class="hero__image-slot" aria-hidden="true">
      <div class="hero__image-placeholder">
        <span class="t-caption hero__image-placeholder-label">Cutout food image</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: var(--sp-6) var(--page-gutter) var(--sp-7);
    background: var(--color-cream);
  }

  .hero__inner {
    max-width: var(--page-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-5);
    align-items: center;
  }

  @media (min-width: 900px) {
    .hero {
      padding: var(--sp-7) var(--page-gutter) var(--sp-8);
    }
    .hero__inner {
      grid-template-columns: 1.05fr 1fr;
      gap: var(--sp-7);
    }
  }

  .hero__kicker {
    color: var(--color-text-muted);
    margin-bottom: var(--sp-4);
  }

  .hero__heading {
    font-size: clamp(var(--fs-700), 9vw, var(--fs-800));
    line-height: 0.96;
    letter-spacing: var(--ls-display-tight);
    margin-bottom: var(--sp-4);
  }

  .hero__heading-line {
    display: block;
  }

  .hero__heading-line--accent {
    color: var(--color-canal);
  }

  /* Hero load animation: letter-spacing tightens, lines reveal */
  .hero__heading-line {
    letter-spacing: var(--ls-display-loose);
    opacity: 0;
    transform: translateY(8px);
    animation: hero-line-in var(--dur-slow) var(--ease-out) forwards;
  }

  .hero__heading-line:nth-child(1) { animation-delay: 80ms; }
  .hero__heading-line:nth-child(2) { animation-delay: 220ms; }
  .hero__heading-line:nth-child(3) { animation-delay: 360ms; }

  @keyframes hero-line-in {
    to {
      letter-spacing: var(--ls-display-tight);
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero__dek {
    font-size: var(--fs-400);
    max-width: 38ch;
    color: color-mix(in srgb, var(--color-ink) 80%, transparent);
    opacity: 0;
    animation: fade-up var(--dur-base) var(--ease-out) 560ms forwards;
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero__ctas {
    margin-top: var(--sp-5);
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    opacity: 0;
    animation: fade-up var(--dur-base) var(--ease-out) 720ms forwards;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-3) var(--sp-4);
    font-family: var(--ff-body-stack);
    font-weight: var(--fw-strong);
    font-size: var(--fs-200);
    text-transform: uppercase;
    letter-spacing: var(--ls-caption);
    text-decoration: none;
    border-radius: var(--r-pill);
    transition: transform var(--dur-fast) var(--ease-out),
                background var(--dur-fast) var(--ease-out);
  }

  .hero__cta--primary {
    background: var(--color-ink);
    color: var(--color-cream);
  }

  .hero__cta--primary:hover,
  .hero__cta--primary:focus-visible {
    transform: translateY(-1px);
    background: color-mix(in srgb, var(--color-ink) 88%, var(--color-canal));
  }

  .hero__cta--secondary {
    background: transparent;
    color: var(--color-ink);
    border: 1.5px solid var(--color-ink);
  }

  .hero__cta--secondary:hover,
  .hero__cta--secondary:focus-visible {
    background: var(--color-ink);
    color: var(--color-cream);
  }

  .hero__cta-arrow {
    transition: transform var(--dur-fast) var(--ease-out);
  }

  .hero__cta:hover .hero__cta-arrow,
  .hero__cta:focus-visible .hero__cta-arrow {
    transform: translateX(3px);
  }

  /* Image slot — placeholder while asset gate is open */
  .hero__image-slot {
    aspect-ratio: 4 / 5;
    background: var(--color-paper);
    border-radius: var(--r-lg);
    display: grid;
    place-items: center;
    overflow: hidden;
    position: relative;
  }

  .hero__image-placeholder {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    background-image:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--color-canal) 12%, transparent) 0,
        color-mix(in srgb, var(--color-canal) 12%, transparent) 12px,
        transparent 12px,
        transparent 24px
      );
  }

  .hero__image-placeholder-label {
    background: var(--color-cream);
    color: var(--color-text-muted);
    padding: var(--sp-1) var(--sp-3);
    border-radius: var(--r-pill);
    border: 1px solid var(--color-line);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__heading-line,
    .hero__dek,
    .hero__ctas {
      animation: none;
      opacity: 1;
      transform: none;
      letter-spacing: var(--ls-display-tight);
    }
  }
</style>
