---
/**
 * Homepage hero — full-bleed cinematic background (video by default,
 * static photo on reduced-motion / load failure), type overlaid on a
 * darkened gradient mask. Owner-provided Falafel kitchen footage is the
 * v1 placeholder; future commissioned brand film swaps via the <video>
 * source attribute.
 *
 * Contrast: type lives over the bottom 50% of the hero where the mask
 * is darkest (>70% black). Cream-coloured display type maintains
 * AAA contrast against the masked photo/video.
 *
 * Perf debt logged in PLACEHOLDERS.md: source MP4 is 5.7 MB pre-encode.
 * Target post-cutover: H.264 sub-2 MB + WebM sub-1.5 MB via ffmpeg.
 */

import { Image } from "astro:assets";
import homeHeroPoster from "../assets/placeholders/home-hero.jpg";
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero__bg" aria-hidden="true">
    <Image
      src={homeHeroPoster}
      alt=""
      class="hero__poster"
      widths={[640, 1024, 1440, 1920, 2400]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      quality={75}
    />
    <video
      class="hero__video"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster=""
    >
      <source src="/videos/home-hero.mp4" type="video/mp4" />
    </video>
    <div class="hero__mask"></div>
  </div>

  {/* WCAG 2.2.2 (Pause, Stop, Hide) — user must be able to stop the
      autoplaying hero video. Toggle is reachable in Tab order and labelled
      for screen readers. Hidden if the system already prefers reduced
      motion (video is display:none in that case via the media query). */}
  <button class="hero__media-toggle" type="button" aria-pressed="false">
    <span class="hero__media-toggle-icon hero__media-toggle-icon--pause" aria-hidden="true">
      <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor">
        <rect x="3.5" y="2.5" width="3" height="11" rx="0.6"></rect>
        <rect x="9.5" y="2.5" width="3" height="11" rx="0.6"></rect>
      </svg>
    </span>
    <span class="hero__media-toggle-icon hero__media-toggle-icon--play" aria-hidden="true">
      <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor">
        <path d="M3.5 2.7c0-.6.7-1 1.2-.66l8.6 5.3c.5.3.5 1 0 1.32l-8.6 5.3c-.5.3-1.2 0-1.2-.66Z"></path>
      </svg>
    </span>
    <span class="hero__media-toggle-label">Pause background video</span>
  </button>

  <div class="hero__content">
    <p class="t-caption hero__kicker">Paddington Basin · Since 2019</p>
    <h1 id="hero-heading" class="t-display hero__heading">SIMPLY.</h1>

    <div class="hero__ctas">
      <a href="/catering/" class="hero__cta hero__cta--primary">
        Hire us for your event
        <span class="hero__cta-arrow" aria-hidden="true">→</span>
      </a>
      <a href="/locations/" class="hero__cta hero__cta--secondary">Find a truck</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    /* Solid dark ground so the section never flashes white pre-paint */
    background: var(--color-ink);
    /* Fill the viewport on every device so the video always paints to the
       edges. `svh` = small-viewport-height — the value when the mobile
       address bar is showing — so the hero never overshoots and creates a
       scroll on first paint. object-fit: cover on the video means it
       crops to whatever shape this viewport gives us; no letterboxing. */
    height: 100svh;
    min-height: 520px;
    color: var(--color-cream);
    display: flex;
    align-items: flex-end;
  }

  @media (min-width: 900px) {
    .hero {
      align-items: center;
    }
  }

  /* Full-bleed background — poster (LCP image), video on top, mask above both */
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  /* The current home-hero.mp4 has ~25% black pillarbox bars on each side
     baked into the 1920×1080 file. Active content is only the centre
     49.1% (~943px) of width. To make that CONTENT fill the viewport on
     any aspect ratio:
       - width = max(viewport-width / 0.491, viewport-height × 16/9)
       - height auto-derives from the video's intrinsic 16:9 aspect
       - centred in both axes so the content sits over the hero centre
     When the video gets replaced with a non-pillarboxed source, revert
     this rule to the simpler `inset: 0; width: 100%; height: 100%;
     object-fit: cover;` pattern. */
  .hero__poster,
  .hero__video {
    position: absolute;
    left: 50%;
    top: 50%;
    width: max(204vw, calc(100svh * 16 / 9));
    /* Override the global media reset that pins media to max-width: 100%,
       which would clamp our intentional viewport-overflow scale. */
    max-width: none;
    height: auto;
    transform: translate(-50%, -50%);
    object-fit: cover;
  }

  .hero__poster {
    z-index: 0;
  }

  .hero__video {
    z-index: 1;
    /* Fade up softly once the video has buffered enough to play. The browser
       paints the poster underneath instantly, so the swap is seamless. */
    opacity: 0;
    transition: opacity var(--dur-slow) var(--ease-out);
  }

  /* When the video can play (or already is playing), reveal it. */
  .hero__video[data-ready] {
    opacity: 1;
  }

  /* Gradient mask — keeps the bottom 60% dark enough for type legibility */
  .hero__mask {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--color-ink) 30%, transparent) 0%,
        color-mix(in srgb, var(--color-ink) 45%, transparent) 40%,
        color-mix(in srgb, var(--color-ink) 78%, transparent) 80%,
        color-mix(in srgb, var(--color-ink) 90%, transparent) 100%
      );
  }

  @media (min-width: 900px) {
    /* Desktop: keep the dark anchor on the left where the type sits */
    .hero__mask {
      background:
        linear-gradient(
          100deg,
          color-mix(in srgb, var(--color-ink) 88%, transparent) 0%,
          color-mix(in srgb, var(--color-ink) 64%, transparent) 40%,
          color-mix(in srgb, var(--color-ink) 18%, transparent) 80%,
          transparent 100%
        );
    }
  }

  /* Type column */
  .hero__content {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: var(--page-max);
    margin: 0 auto;
    padding: var(--sp-7) var(--page-gutter) var(--sp-6);
  }

  @media (min-width: 900px) {
    .hero__content {
      padding: var(--sp-7) var(--page-gutter);
    }
    .hero__content > * {
      max-width: 22ch;
    }
    .hero__dek { max-width: 38ch; }
    .hero__ctas { max-width: none; }
  }

  .hero__kicker {
    color: color-mix(in srgb, var(--color-cream) 75%, transparent);
    margin-bottom: var(--sp-3);
  }

  .hero__heading {
    /* Wordmark — display type sized to dominate the viewport like a poster.
       Letter-spacing tightens on entry. */
    font-size: clamp(4rem, 18vw, 12rem);
    line-height: 0.86;
    letter-spacing: var(--ls-display-tight);
    margin: 0;
    color: var(--color-cream);
    letter-spacing: var(--ls-display-loose);
    opacity: 0;
    transform: translateY(8px);
    animation: hero-line-in var(--dur-slow) var(--ease-out) 200ms forwards;
  }

  @keyframes hero-line-in {
    to {
      letter-spacing: var(--ls-display-tight);
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero__ctas {
    margin-top: var(--sp-5);
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    opacity: 0;
    animation: fade-up var(--dur-base) var(--ease-out) 480ms forwards;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-3) var(--sp-4);
    font-family: var(--ff-body-stack);
    font-weight: var(--fw-strong);
    font-size: var(--fs-200);
    text-transform: uppercase;
    letter-spacing: var(--ls-caption);
    text-decoration: none;
    border-radius: var(--r-pill);
    transition: transform var(--dur-fast) var(--ease-out),
                background var(--dur-fast) var(--ease-out);
  }

  .hero__cta--primary {
    background: var(--color-cream);
    color: var(--color-ink);
  }

  .hero__cta--primary:hover,
  .hero__cta--primary:focus-visible {
    transform: translateY(-1px);
    background: #fff;
  }

  .hero__cta--secondary {
    background: transparent;
    color: var(--color-cream);
    border: 1.5px solid var(--color-cream);
  }

  .hero__cta--secondary:hover,
  .hero__cta--secondary:focus-visible {
    background: var(--color-cream);
    color: var(--color-ink);
  }

  .hero__cta-arrow {
    transition: transform var(--dur-fast) var(--ease-out);
  }

  .hero__cta:hover .hero__cta-arrow,
  .hero__cta:focus-visible .hero__cta-arrow {
    transform: translateX(3px);
  }

  /* Focus outlines on the cream-on-dark hero */
  .hero :focus-visible {
    outline: 2px solid var(--color-cream);
    outline-offset: 3px;
  }

  /* WCAG 2.2.2 — Pause/Stop/Hide control for the autoplaying hero video.
     Sits top-right of the hero section, above the mask + content layers. */
  .hero__media-toggle {
    position: absolute;
    top: var(--sp-4);
    right: var(--sp-4);
    z-index: 4;
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-3);
    background: color-mix(in srgb, var(--color-ink) 70%, transparent);
    color: var(--color-cream);
    border: 1px solid color-mix(in srgb, var(--color-cream) 35%, transparent);
    border-radius: var(--r-pill);
    font-family: var(--ff-body-stack);
    font-weight: var(--fw-strong);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: var(--ls-caption);
    cursor: pointer;
    transition: background var(--dur-fast) var(--ease-out),
                border-color var(--dur-fast) var(--ease-out);
  }
  .hero__media-toggle:hover,
  .hero__media-toggle:focus-visible {
    background: color-mix(in srgb, var(--color-ink) 85%, transparent);
    border-color: var(--color-cream);
  }
  .hero__media-toggle-icon {
    display: inline-flex;
    line-height: 0;
  }
  /* Pause icon shows while video is playing; play icon shows while paused. */
  .hero__media-toggle .hero__media-toggle-icon--play { display: none; }
  .hero__media-toggle[aria-pressed="true"] .hero__media-toggle-icon--pause { display: none; }
  .hero__media-toggle[aria-pressed="true"] .hero__media-toggle-icon--play { display: inline-flex; }
  .hero__media-toggle-label {
    /* Visible label keeps the toggle obvious; auto-hide on small screens via
       responsive rule below if it crowds the type. */
  }
  @media (max-width: 559px) {
    .hero__media-toggle-label {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
    .hero__media-toggle {
      padding: var(--sp-2);
    }
  }

  /* Reduced motion: hide the video AND the toggle (no autoplay = no need
     for a stop control). Poster persists as a permanent still. */
  @media (prefers-reduced-motion: reduce) {
    .hero__video { display: none; }
    .hero__media-toggle { display: none; }
    .hero__heading,
    .hero__ctas {
      animation: none;
      opacity: 1;
      transform: none;
      letter-spacing: var(--ls-display-tight);
    }
  }
</style>

<script>
  // Reveal the video once it has at least one playable frame buffered.
  // The poster stays visible underneath, so the transition is seamless.
  const video = document.querySelector(".hero__video");
  if (video instanceof HTMLVideoElement) {
    const ready = () => video.setAttribute("data-ready", "");
    if (video.readyState >= 2) {
      ready();
    } else {
      video.addEventListener("loadeddata", ready, { once: true });
      video.addEventListener("playing", ready, { once: true });
    }
  }

  // WCAG 2.2.2 — user-operable pause/play control.
  const toggle = document.querySelector(".hero__media-toggle");
  const label = document.querySelector(".hero__media-toggle-label");
  if (
    toggle instanceof HTMLButtonElement &&
    video instanceof HTMLVideoElement &&
    label instanceof HTMLElement
  ) {
    const sync = () => {
      const paused = video.paused;
      toggle.setAttribute("aria-pressed", paused ? "true" : "false");
      label.textContent = paused ? "Play background video" : "Pause background video";
    };
    toggle.addEventListener("click", () => {
      if (video.paused) {
        void video.play();
      } else {
        video.pause();
      }
      sync();
    });
    video.addEventListener("play", sync);
    video.addEventListener("pause", sync);
    sync();
  }
</script>
