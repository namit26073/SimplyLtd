---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";

interface Props {
  brand: CollectionEntry<"brands">["data"];
  pitch: CollectionEntry<"locations">["data"] | null;
}

const { brand, pitch } = Astro.props;

const wordmark = brand.name.replace(/^Simply\s+/i, "");
---

<a
  href={`/${brand.slug}/`}
  class="panel"
  data-brand={brand.slug}
  aria-labelledby={`panel-${brand.slug}-heading`}
>
  {brand.showcaseImage ? (
    <div class="panel__photo-wrap" aria-hidden="true">
      <Image
        src={brand.showcaseImage}
        alt=""
        class="panel__photo"
        widths={[400, 600, 800, 1200]}
        sizes="(min-width: 900px) 33vw, 80vw"
        loading="lazy"
        quality={75}
      />
    </div>
  ) : null}

  <div class="panel__content">
    <p class="t-caption panel__kicker">Simply</p>
    <h3 id={`panel-${brand.slug}-heading`} class="t-display panel__wordmark">{wordmark}</h3>
    <p class="t-body panel__tagline">{brand.tagline}</p>
    {pitch && <p class="t-caption panel__meta">{pitch.name} · {pitch.postcode}</p>}
    <span class="panel__cta" aria-hidden="true">
      Visit Simply {wordmark} <span class="panel__cta-arrow">→</span>
    </span>
  </div>
</a>

<style>
  .panel {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: var(--r-lg);
    background: var(--color-accent);
    color: var(--color-accent-contrast);
    aspect-ratio: 3 / 4;
    text-decoration: none;
    isolation: isolate;
    transition: transform var(--dur-base) var(--ease-out);
  }

  .panel:hover,
  .panel:focus-visible {
    transform: translateY(-4px);
  }

  /* Photo wrap — top portion of the panel only. The content box below has
     its own solid-accent backdrop and covers the lower half, so the wrap
     doesn't need to extend the full height; constraining it lets us
     control how MUCH of the photo's vertical range is shown. A subtle
     bottom fade blends the wrap into the content-box backdrop beneath. */
  .panel__photo-wrap {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 62%;
    z-index: 0;
    pointer-events: none;
    -webkit-mask-image: linear-gradient(
      180deg,
      #000 0%,
      #000 78%,
      rgba(0, 0, 0, 0.5) 92%,
      transparent 100%
    );
    mask-image: linear-gradient(
      180deg,
      #000 0%,
      #000 78%,
      rgba(0, 0, 0, 0.5) 92%,
      transparent 100%
    );
  }

  /* The photo itself sits inside the masked wrap. :global() pierces
     Astro Image's component-scoped class. */
  :global(.panel__photo) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Bottom-align the photo. The placeholder food images put the subject
       in the lower 25-50% (falafel bowl rows 75-100%, burger patties
       50-95%, shawarma wrap 35-80%); bottom-aligning shows photo rows
       ~43-100% in the wrap, which centres the food cleanly in the
       visible photo band on both mobile and desktop. */
    object-position: center 100%;
    transition: transform var(--dur-slow) var(--ease-out);
  }

  .panel:hover :global(.panel__photo),
  .panel:focus-visible :global(.panel__photo) {
    transform: scale(1.04);
  }

  /* Soft brand-tint layer over the photo. Light at the top, transparent in
     the middle (photo blooms through), light tint at the bottom — the
     readable-text band is handled by the .panel__content backdrop below,
     not by overloading this layer. */
  .panel::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-accent) 18%, transparent) 0%,
      transparent 32%,
      transparent 60%,
      color-mix(in srgb, var(--color-accent) 25%, transparent) 78%,
      color-mix(in srgb, var(--color-accent) 55%, transparent) 92%
    );
  }

  /* Text-area backdrop. The content block is anchored to the bottom; its
     own background gradient fades in from transparent at the top edge
     (so the photo bloom above transitions smoothly) to solid accent at
     ~14% of the box height — kicker line lands inside the solid zone.
     This isolates the readable-text band from the photo without flooding
     the whole panel with solid colour. */
  .panel__content {
    position: absolute;
    inset: auto 0 0 0;
    z-index: 2;
    padding: var(--sp-5);
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    background: linear-gradient(
      180deg,
      transparent 0%,
      color-mix(in srgb, var(--color-accent) 88%, transparent) 8%,
      var(--color-accent) 18%,
      var(--color-accent) 100%
    );
  }

  .panel__kicker {
    color: var(--color-accent-contrast);
    margin-bottom: var(--sp-1);
  }

  .panel__wordmark {
    font-size: clamp(var(--fs-700), 6vw, var(--fs-800));
    line-height: 0.86;
    letter-spacing: var(--ls-display-tight);
    text-transform: uppercase;
    color: var(--color-accent-contrast);
  }

  .panel__tagline {
    font-size: var(--fs-300);
    line-height: var(--lh-snug);
    color: var(--color-accent-contrast);
    max-width: 28ch;
    margin-top: var(--sp-2);
  }

  .panel__meta {
    color: var(--color-accent-contrast);
    margin-top: var(--sp-2);
  }

  .panel__cta {
    margin-top: var(--sp-3);
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--ff-body-stack);
    font-weight: var(--fw-strong);
    font-size: var(--fs-200);
    text-transform: uppercase;
    letter-spacing: var(--ls-caption);
    color: var(--color-accent-contrast);
    border-bottom: 2px solid var(--color-accent-contrast);
    padding-bottom: var(--sp-1);
    align-self: flex-start;
  }

  .panel__cta-arrow {
    transition: transform var(--dur-fast) var(--ease-out);
  }

  .panel:hover .panel__cta-arrow,
  .panel:focus-visible .panel__cta-arrow {
    transform: translateX(4px);
  }

  .panel:focus-visible {
    outline: 2px solid var(--color-accent-contrast);
    outline-offset: 3px;
  }
</style>
