---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";

interface Props {
  brand: CollectionEntry<"brands">["data"];
  pitch: CollectionEntry<"locations">["data"] | null;
}

const { brand, pitch } = Astro.props;

const wordmark = brand.name.replace(/^Simply\s+/i, "");
---

<a
  href={`/${brand.slug}/`}
  class="panel"
  data-brand={brand.slug}
  aria-labelledby={`panel-${brand.slug}-heading`}
>
  {brand.showcaseImage ? (
    <div class="panel__photo-wrap" aria-hidden="true">
      <Image
        src={brand.showcaseImage}
        alt=""
        class="panel__photo"
        widths={[400, 600, 800, 1200]}
        sizes="(min-width: 900px) 33vw, 80vw"
        loading="lazy"
        quality={75}
      />
    </div>
  ) : null}

  <div class="panel__content">
    <p class="t-caption panel__kicker">Simply</p>
    <h3 id={`panel-${brand.slug}-heading`} class="t-display panel__wordmark">{wordmark}</h3>
    <p class="t-body panel__tagline">{brand.tagline}</p>
    {pitch && <p class="t-caption panel__meta">{pitch.name} · {pitch.postcode}</p>}
    <span class="panel__cta" aria-hidden="true">
      Visit Simply {wordmark} <span class="panel__cta-arrow">→</span>
    </span>
  </div>
</a>

<style>
  .panel {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: var(--r-lg);
    background: var(--color-accent);
    color: var(--color-accent-contrast);
    aspect-ratio: 3 / 4;
    text-decoration: none;
    isolation: isolate;
    transition: transform var(--dur-base) var(--ease-out);
  }

  .panel:hover,
  .panel:focus-visible {
    transform: translateY(-4px);
  }

  /* Photo wrap. mask-image feathers the top + bottom of the photo into the
     brand-coloured ground beneath, so the image reads as a bloom of food
     out of the brand colour rather than a rectangular cut-out sitting on
     top. This is the "transparent-feeling" treatment without needing
     PNG cutouts from the asset side. */
  .panel__photo-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    -webkit-mask-image: linear-gradient(
      180deg,
      transparent 0%,
      rgba(0, 0, 0, 0.55) 12%,
      #000 28%,
      #000 58%,
      rgba(0, 0, 0, 0.55) 78%,
      transparent 96%
    );
    mask-image: linear-gradient(
      180deg,
      transparent 0%,
      rgba(0, 0, 0, 0.55) 12%,
      #000 28%,
      #000 58%,
      rgba(0, 0, 0, 0.55) 78%,
      transparent 96%
    );
  }

  /* The photo itself sits inside the masked wrap. :global() pierces
     Astro Image's component-scoped class. */
  :global(.panel__photo) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Pull the subject upward (most food / portrait shots have the focal
       weight in the upper third). The wrap's bottom feather then handles
       the blend into the text band cleanly. */
    object-position: center 32%;
    transition: transform var(--dur-slow) var(--ease-out);
  }

  .panel:hover :global(.panel__photo),
  .panel:focus-visible :global(.panel__photo) {
    transform: scale(1.04);
  }

  /* Brand-tint layer. Light at the top so the photo reads through; ramps to
     solid accent in the bottom ~12% so the wordmark + tagline + CTA always
     sit on a known brand-coloured ground (no photo-pixel bleed under text,
     which was failing AA on the shawarma yellow + falafel green panels). */
  .panel::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-accent) 18%, transparent) 0%,
      transparent 32%,
      color-mix(in srgb, var(--color-accent) 30%, transparent) 56%,
      color-mix(in srgb, var(--color-accent) 78%, transparent) 76%,
      var(--color-accent) 92%,
      var(--color-accent) 100%
    );
  }

  .panel__content {
    position: absolute;
    inset: auto 0 0 0;
    z-index: 2;
    padding: var(--sp-5);
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .panel__kicker {
    color: var(--color-accent-contrast);
    margin-bottom: var(--sp-1);
  }

  .panel__wordmark {
    font-size: clamp(var(--fs-700), 6vw, var(--fs-800));
    line-height: 0.86;
    letter-spacing: var(--ls-display-tight);
    text-transform: uppercase;
    color: var(--color-accent-contrast);
  }

  .panel__tagline {
    font-size: var(--fs-300);
    line-height: var(--lh-snug);
    color: var(--color-accent-contrast);
    max-width: 28ch;
    margin-top: var(--sp-2);
  }

  .panel__meta {
    color: var(--color-accent-contrast);
    margin-top: var(--sp-2);
  }

  .panel__cta {
    margin-top: var(--sp-3);
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--ff-body-stack);
    font-weight: var(--fw-strong);
    font-size: var(--fs-200);
    text-transform: uppercase;
    letter-spacing: var(--ls-caption);
    color: var(--color-accent-contrast);
    border-bottom: 2px solid var(--color-accent-contrast);
    padding-bottom: var(--sp-1);
    align-self: flex-start;
  }

  .panel__cta-arrow {
    transition: transform var(--dur-fast) var(--ease-out);
  }

  .panel:hover .panel__cta-arrow,
  .panel:focus-visible .panel__cta-arrow {
    transform: translateX(4px);
  }

  .panel:focus-visible {
    outline: 2px solid var(--color-accent-contrast);
    outline-offset: 3px;
  }
</style>
