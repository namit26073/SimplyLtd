---
import type { CollectionEntry } from "astro:content";

interface Props {
  brand: CollectionEntry<"brands">["data"];
  pitch: CollectionEntry<"locations">["data"] | null;
  index: number;
  total: number;
}

const { brand, pitch, index, total } = Astro.props;

const wordmark = brand.name.replace(/^Simply\s+/i, "");
const indexLabel = `${String(index + 1).padStart(2, "0")} / ${String(total).padStart(2, "0")}`;
---

<article class="panel" data-brand={brand.slug} aria-labelledby={`panel-${brand.slug}-heading`}>
  <div class="panel__inner">
    <div class="panel__copy">
      <p class="t-caption panel__index" aria-hidden="true">{indexLabel}</p>
      <p class="t-caption panel__concept">Simply</p>
      <h3 id={`panel-${brand.slug}-heading`} class="t-display panel__wordmark">{wordmark}</h3>

      <p class="t-editorial t-editorial--italic panel__dek">{brand.introDek}</p>

      <ul role="list" class="panel__meta">
        {pitch && <li class="t-caption">{pitch.name} · {pitch.postcode}</li>}
        {brand.dietary?.map((tag) => <li class="t-caption">{tag}</li>)}
      </ul>

      <a href={`/${brand.slug}/`} class="panel__cta">
        See {brand.name}
        <span aria-hidden="true">→</span>
      </a>
    </div>

    {/* Cutout zone — bleeds off the bottom-right corner of the panel. The
        shape is a soft wash standing in for the eventual brand cutout PNG.
        When the real asset lands, replace the .panel__shape with an
        <Image /> element at the same anchor (bottom: -10%, right: -8%). */}
    <span class="panel__shape" aria-hidden="true"></span>
  </div>
</article>

<style>
  .panel {
    background: var(--color-accent);
    color: var(--color-accent-contrast);
    border-radius: var(--r-lg);
    overflow: hidden;
    scroll-snap-align: start;
    position: relative;
  }

  .panel__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    min-height: 70vh;
    padding: var(--sp-5) var(--sp-5) var(--sp-6);
    gap: var(--sp-4);
  }

  @media (min-width: 900px) {
    .panel__inner {
      grid-template-columns: 1.4fr 1fr;
      align-items: center;
      padding: var(--sp-7);
      min-height: 78vh;
      gap: var(--sp-6);
    }
  }

  .panel__copy {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    max-width: 40rem;
  }

  .panel__index {
    color: var(--color-accent-contrast);
  }

  .panel__concept {
    color: var(--color-accent-contrast);
    margin-top: var(--sp-3);
  }

  .panel__wordmark {
    font-size: clamp(var(--fs-800), 18vw, var(--fs-900));
    line-height: 0.86;
    letter-spacing: var(--ls-display-tight);
    margin-top: calc(-1 * var(--sp-2));
    text-transform: uppercase;
    opacity: 0;
    transform: translateY(20px);
    animation: panel-wordmark-in var(--dur-slow) var(--ease-out) forwards;
    animation-timeline: view();
    animation-range: entry 0% cover 30%;
  }

  @supports not (animation-timeline: view()) {
    .panel__wordmark {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }

  @keyframes panel-wordmark-in {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .panel__dek {
    font-size: clamp(var(--fs-400), 2.6vw, var(--fs-500));
    max-width: 32ch;
    margin-top: var(--sp-3);
  }

  .panel__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-1) var(--sp-3);
    margin-top: var(--sp-3);
    align-items: center;
  }

  .panel__meta li {
    padding: var(--sp-1) var(--sp-3);
    border: 1px solid color-mix(in srgb, currentColor 55%, transparent);
    border-radius: var(--r-pill);
  }

  .panel__cta {
    margin-top: var(--sp-4);
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    align-self: flex-start;
    padding: var(--sp-3) var(--sp-4);
    background: var(--color-accent-contrast);
    color: var(--color-accent);
    font-family: var(--ff-body-stack);
    font-weight: var(--fw-strong);
    font-size: var(--fs-200);
    text-transform: uppercase;
    letter-spacing: var(--ls-caption);
    text-decoration: none;
    border-radius: var(--r-pill);
    transition: transform var(--dur-fast) var(--ease-out);
  }

  .panel__cta:hover,
  .panel__cta:focus-visible {
    transform: translateY(-1px);
  }

  /* Cutout shape — sized to a real food-cutout footprint (portrait, ~300-
     400px), anchored in the bottom-right of the panel with a small bleed.
     Replaces the previous design-reviewer-flagged "giant disc behind type."
     When the real PNG arrives, swap for <Image /> at the same anchor. */
  .panel__shape {
    position: absolute;
    display: block;
    pointer-events: none;
    border-radius: 48% 52% 50% 50%; /* faintly organic */
    width: clamp(220px, 48vw, 320px);
    aspect-ratio: 4 / 5;
    right: -6%;
    bottom: -8%;
    background:
      radial-gradient(
        ellipse at 50% 50%,
        color-mix(in srgb, var(--color-accent-contrast) 30%, transparent) 0%,
        color-mix(in srgb, var(--color-accent-contrast) 12%, transparent) 38%,
        transparent 68%
      );
  }

  @media (min-width: 900px) {
    .panel__shape {
      width: clamp(300px, 32%, 460px);
      right: 4%;
      bottom: 4%;
    }
  }

  .panel :focus-visible {
    outline: 2px solid var(--color-accent-contrast);
    outline-offset: 3px;
  }
</style>
