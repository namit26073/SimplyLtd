---
import { getCollection, getEntry } from "astro:content";
import BrandPanel from "./BrandPanel.astro";

const allBrands = await getCollection("brands");
const visibleBrands = allBrands
  .filter((b) => b.data.visible)
  .sort((a, b) => a.data.order - b.data.order);

const brandsWithPitches = await Promise.all(
  visibleBrands.map(async (entry) => {
    const pitch = entry.data.primaryPitchSlug
      ? await getEntry("locations", entry.data.primaryPitchSlug)
      : null;
    return { brand: entry.data, pitch: pitch?.data ?? null };
  }),
);
---

<section id="brand-showcase" class="showcase" aria-labelledby="showcase-heading">
  <header class="showcase__header">
    <p class="t-caption showcase__kicker">The fleet</p>
    <h2 id="showcase-heading" class="t-display showcase__heading">
      Three trucks. One canal.
    </h2>
  </header>

  <div class="showcase__rail" role="list" aria-label="Sub-brands">
    {
      brandsWithPitches.map(({ brand, pitch }) => (
        <div role="listitem" class="showcase__cell">
          <BrandPanel brand={brand} pitch={pitch} />
        </div>
      ))
    }
  </div>
</section>

<style>
  .showcase {
    padding: var(--sp-7) var(--page-gutter);
    background: var(--color-cream);
    border-top: 1px solid var(--color-line);
  }

  .showcase__header {
    max-width: var(--page-max);
    margin: 0 auto var(--sp-5);
  }

  .showcase__kicker {
    color: var(--color-text-muted);
    margin-bottom: var(--sp-2);
  }

  .showcase__heading {
    font-size: clamp(var(--fs-600), 5vw, var(--fs-700));
    line-height: 0.96;
    letter-spacing: var(--ls-display-tight);
  }

  /* Card rail.
     Desktop: 3 equal columns side-by-side, capped by --page-max.
     Mobile: horizontal scroll-snap with peek of the next card. */
  .showcase__rail {
    max-width: var(--page-max);
    margin: 0 auto;
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 80%;
    gap: var(--sp-3);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-bottom: var(--sp-2);
    /* Hide scrollbar in modern browsers while keeping scrollable */
    scrollbar-width: none;
  }
  .showcase__rail::-webkit-scrollbar {
    display: none;
  }

  .showcase__cell {
    scroll-snap-align: start;
  }

  @media (min-width: 900px) {
    .showcase__rail {
      grid-auto-columns: unset;
      grid-auto-flow: row;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--sp-4);
      overflow: visible;
    }
  }
</style>
