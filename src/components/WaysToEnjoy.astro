---
/**
 * Editorial grid below the hero. Four routes, four sizes.
 * Each tile is a brand-coloured ground with a feathered photo blending in
 * from one corner (CSS mask-image radial-gradient — no hard photo edges,
 * the photo "blooms" out of the brand colour rather than sitting on top).
 *
 * Photos reuse the hero placeholders for catering + franchising (the tile
 * previews the page it links to). Menu uses a separate food-spread shot;
 * Locations is a Paddington-Basin / canal placeholder until owner photos.
 */

import { Image } from "astro:assets";
import cateringHero from "../assets/placeholders/catering-hero.jpg";
import franchiseHero from "../assets/placeholders/franchising-hero.jpg";
import wteLocations from "../assets/placeholders/wte-locations.jpg";

type Slot = "catering" | "franchising" | "locations";

type Card = {
  slot: Slot;
  kicker: string;
  heading: string;
  cta: { label: string; href: string };
  accent: "ink" | "falafel" | "burgers";
};

const cards: Card[] = [
  {
    slot: "catering",
    kicker: "Catering",
    heading: "Hire us for your event.",
    cta: { label: "Get a quote", href: "/catering/" },
    accent: "ink",
  },
  {
    slot: "franchising",
    kicker: "Franchising",
    heading: "Run a truck of your own.",
    cta: { label: "See how", href: "/franchising/" },
    accent: "burgers",
  },
  {
    slot: "locations",
    kicker: "Locations",
    heading: "Find us on the basin.",
    cta: { label: "See the map", href: "/locations/" },
    accent: "falafel",
  },
];

const photoFor = (slot: Slot) => {
  if (slot === "catering") return cateringHero;
  if (slot === "franchising") return franchiseHero;
  if (slot === "locations") return wteLocations;
  return null;
};
---

<section class="wte" aria-labelledby="wte-heading">
  <div class="wte__inner">
    <header class="wte__header">
      <h2 id="wte-heading" class="t-display wte__heading">What's next?</h2>
    </header>

    <ul role="list" class="wte__grid">
      {
        cards.map((card) => {
          const photo = photoFor(card.slot);
          return (
            <li
              class={`wte__card wte__card--${card.slot}`}
              data-brand={card.accent === "ink" ? undefined : card.accent}
            >
              {photo ? (
                <Image
                  src={photo}
                  alt=""
                  class="wte__photo"
                  widths={[360, 540, 720, 1080]}
                  sizes="(min-width: 900px) 33vw, 100vw"
                  loading="lazy"
                  quality={72}
                />
              ) : null}
              <a href={card.cta.href} class="wte__link">
                <div class="wte__top">
                  <span class="wte__kicker t-caption">{card.kicker}</span>
                  <span class="wte__heading-label t-display">{card.heading}</span>
                </div>
                <span class="wte__cta-label">
                  {card.cta.label}
                  <span aria-hidden="true">→</span>
                </span>
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>

<style>
  .wte {
    padding: var(--sp-6) var(--page-gutter) var(--sp-7);
    background: var(--color-cream);
    border-top: 1px solid var(--color-line);
  }

  .wte__inner {
    max-width: var(--page-max);
    margin: 0 auto;
  }

  .wte__header {
    margin-bottom: var(--sp-4);
  }

  .wte__heading {
    font-size: clamp(var(--fs-500), 4vw, var(--fs-600));
    line-height: 0.96;
    color: var(--color-ink);
  }

  /* Balanced 3-up grid — smaller, less feature-y than the prior asymmetric
     layout. Stays distinct from the BrandShowcase rail above by being
     wider/shorter (landscape tiles) vs. the showcase's portrait cards. */
  .wte__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-3);
  }

  @media (min-width: 900px) {
    .wte__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--sp-3);
    }
  }

  .wte__card {
    position: relative;
    overflow: hidden;
    border-radius: var(--r-lg);
    background: var(--color-accent, var(--color-ink));
    color: var(--color-accent-contrast, var(--color-cream));
    isolation: isolate;
    aspect-ratio: 16 / 10;
  }

  @media (min-width: 900px) {
    .wte__card {
      aspect-ratio: 4 / 3;
    }
  }

  /* Photo behind everything. :global() pierces Astro Image's scope. */
  :global(.wte__photo) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 45%;
    z-index: 0;
    pointer-events: none;
    transition: transform var(--dur-slow) var(--ease-out);
  }

  /* Brand-coloured tint anchored bottom-left where the heading + CTA sit. */
  .wte__card::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      135deg,
      var(--color-accent, var(--color-ink)) 0%,
      var(--color-accent, var(--color-ink)) 38%,
      color-mix(in srgb, var(--color-accent, var(--color-ink)) 60%, transparent) 60%,
      color-mix(in srgb, var(--color-accent, var(--color-ink)) 15%, transparent) 88%,
      color-mix(in srgb, var(--color-accent, var(--color-ink)) 0%, transparent) 100%
    );
  }

  .wte__link {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--sp-4) var(--sp-4) var(--sp-4);
    color: var(--color-accent-contrast);
    text-decoration: none;
    transition: transform var(--dur-base) var(--ease-out);
  }

  .wte__card:hover .wte__link,
  .wte__card:has(.wte__link:focus-visible) .wte__link {
    transform: translateY(-2px);
  }

  .wte__card:hover :global(.wte__photo),
  .wte__card:has(.wte__link:focus-visible) :global(.wte__photo) {
    transform: scale(1.04);
  }

  .wte__top {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .wte__kicker {
    color: var(--color-accent-contrast);
  }

  .wte__heading-label {
    font-size: clamp(var(--fs-500), 3vw, var(--fs-600));
    line-height: 1;
    letter-spacing: var(--ls-display-tight);
    color: var(--color-accent-contrast);
    max-width: 14ch;
  }

  .wte__cta-label {
    margin-top: var(--sp-3);
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--ff-body-stack);
    font-weight: var(--fw-strong);
    font-size: var(--fs-200);
    text-transform: uppercase;
    letter-spacing: var(--ls-caption);
    color: var(--color-accent-contrast);
    border-bottom: 2px solid var(--color-accent-contrast);
    padding-bottom: var(--sp-1);
    align-self: flex-start;
    transition: gap var(--dur-fast) var(--ease-out);
  }

  .wte__card:hover .wte__cta-label,
  .wte__card:has(.wte__link:focus-visible) .wte__cta-label {
    gap: var(--sp-3);
  }

  .wte__link:focus-visible {
    outline: 2px solid var(--color-accent-contrast);
    outline-offset: -4px;
    border-radius: var(--r-lg);
  }
</style>
