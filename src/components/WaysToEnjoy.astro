---
/**
 * Editorial grid below the hero. Four routes, four sizes.
 * Each tile is a brand-coloured ground with a feathered photo blending in
 * from one corner (CSS mask-image radial-gradient — no hard photo edges,
 * the photo "blooms" out of the brand colour rather than sitting on top).
 *
 * Photos reuse the hero placeholders for catering + franchising (the tile
 * previews the page it links to). Menu uses a separate food-spread shot;
 * Locations is a Paddington-Basin / canal placeholder until owner photos.
 */

import { Image } from "astro:assets";
import cateringHero from "../assets/placeholders/catering-hero.jpg";
import franchiseHero from "../assets/placeholders/franchising-hero.jpg";
import wteMenu from "../assets/placeholders/wte-menu.jpg";
import wteLocations from "../assets/placeholders/wte-locations.jpg";

type Slot = "catering" | "franchising" | "locations" | "menu";

type Card = {
  slot: Slot;
  eyebrow: string;
  heading: string;
  body: string;
  cta: { label: string; href: string };
  accent: "ink" | "falafel" | "shawarma" | "burgers";
};

const cards: Card[] = [
  {
    slot: "catering",
    eyebrow: "Catering",
    heading: "Bring street food to your event.",
    body: "Weddings, festivals, corporate, private. We bring the trucks, the team, and the queue that doesn't stop.",
    cta: { label: "Get a quote", href: "/catering/" },
    accent: "ink",
  },
  {
    slot: "franchising",
    eyebrow: "Franchising",
    heading: "Run a Simply truck of your own.",
    body: "Three concepts on the canal, more in the wings. One operating model, six years of pitch-tested practice.",
    cta: { label: "See how it works", href: "/franchising/" },
    accent: "burgers",
  },
  {
    slot: "menu",
    eyebrow: "Our brands",
    heading: "What we cook.",
    body: "Falafel, Shawarma, Burgers — each its own concept, each with its own kitchen.",
    cta: { label: "Explore the fleet", href: "#brand-showcase" },
    accent: "shawarma",
  },
  {
    slot: "locations",
    eyebrow: "Locations",
    heading: "Find your nearest pitch on the basin.",
    body: "Three trucks on Paddington Basin. Falafel and Shawarma at Merchant Square; Burgers on Canal Side Walk.",
    cta: { label: "See the map", href: "/locations/" },
    accent: "falafel",
  },
];

const photoFor = (slot: Slot) => {
  if (slot === "catering") return cateringHero;
  if (slot === "franchising") return franchiseHero;
  if (slot === "menu") return wteMenu;
  if (slot === "locations") return wteLocations;
  return null;
};
---

<section class="wte" aria-labelledby="wte-heading">
  <div class="wte__inner">
    <header class="wte__header">
      <p class="t-caption wte__kicker">Four ways to enjoy Simply</p>
      <h2 id="wte-heading" class="t-display wte__heading">Choose your queue.</h2>
    </header>

    <ul role="list" class="wte__grid">
      {
        cards.map((card) => {
          const photo = photoFor(card.slot);
          return (
            <li
              class={`wte__card wte__card--${card.slot}`}
              data-brand={card.accent === "ink" ? undefined : card.accent}
            >
              {photo ? (
                <Image
                  src={photo}
                  alt=""
                  class="wte__photo"
                  widths={[480, 768, 1024, 1440]}
                  sizes="(min-width: 900px) 50vw, 100vw"
                  loading="lazy"
                  quality={72}
                />
              ) : null}
              <article class="wte__card-inner">
                <div class="wte__copy">
                  <p class="t-caption wte__eyebrow">{card.eyebrow}</p>
                  <h3 class="t-display wte__card-heading">{card.heading}</h3>
                  <p class="t-body wte__body">{card.body}</p>
                  <a href={card.cta.href} class="wte__cta">
                    {card.cta.label}
                    <span aria-hidden="true">→</span>
                  </a>
                </div>
              </article>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>

<style>
  .wte {
    padding: var(--sp-7) var(--page-gutter);
    background: var(--color-cream);
    border-top: 1px solid var(--color-line);
  }

  .wte__inner {
    max-width: var(--page-max);
    margin: 0 auto;
  }

  .wte__header {
    margin-bottom: var(--sp-6);
    max-width: var(--measure-prose);
  }

  .wte__kicker {
    color: var(--color-text-muted);
    margin-bottom: var(--sp-2);
  }

  .wte__heading {
    font-size: clamp(var(--fs-600), 6vw, var(--fs-700));
    line-height: 0.96;
  }

  /* Asymmetric editorial grid */
  .wte__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-4);
  }

  @media (min-width: 900px) {
    .wte__grid {
      grid-template-columns: 1.45fr 1fr;
      grid-template-rows: minmax(260px, auto) minmax(260px, auto) minmax(200px, auto);
      grid-template-areas:
        "catering franchising"
        "catering menu"
        "locations locations";
      gap: var(--sp-4);
    }
  }

  .wte__card--catering { grid-area: catering; }
  .wte__card--franchising { grid-area: franchising; }
  .wte__card--menu { grid-area: menu; }
  .wte__card--locations { grid-area: locations; }

  .wte__card {
    position: relative;
    overflow: hidden;
    border-radius: var(--r-lg);
    background: var(--color-accent, var(--color-ink));
    color: var(--color-accent-contrast, var(--color-cream));
    transition: transform var(--dur-base) var(--ease-out);
    height: 100%;
    align-self: stretch;
    isolation: isolate;
  }

  .wte__card:has(.wte__cta:hover),
  .wte__card:has(.wte__cta:focus-visible) {
    transform: translateY(-3px);
  }

  /* Photo — full-bleed background. Brand-coloured gradient mask sits ABOVE
     the photo (pseudo-element below) to give text a high-contrast anchor on
     one side while the photo bleeds visibly on the other. Pattern matches
     the hero treatment scaled to a card.
     :global() pierces Astro Image's scope so .wte__photo styles land on
     the rendered <img>. */
  :global(.wte__photo) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 45%;
    z-index: 0;
    pointer-events: none;
  }

  /* Brand-coloured tint gradient — anchors the type side, fades to reveal
     the photo on the opposite side. Direction varies by tile shape. */
  .wte__card::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    /* Mobile default: vertical mask — brand colour anchors top where type
       sits, photo reveals at bottom. */
    background: linear-gradient(
      180deg,
      var(--color-accent, var(--color-ink)) 0%,
      var(--color-accent, var(--color-ink)) 30%,
      color-mix(in srgb, var(--color-accent, var(--color-ink)) 80%, transparent) 55%,
      color-mix(in srgb, var(--color-accent, var(--color-ink)) 30%, transparent) 90%,
      color-mix(in srgb, var(--color-accent, var(--color-ink)) 0%, transparent) 100%
    );
  }

  @media (min-width: 900px) {
    /* Desktop tiles in the right column (franchising / menu / locations
       strip): horizontal mask — copy left, photo right. */
    .wte__card--franchising::before,
    .wte__card--menu::before,
    .wte__card--locations::before {
      background: linear-gradient(
        100deg,
        var(--color-accent, var(--color-ink)) 0%,
        var(--color-accent, var(--color-ink)) 35%,
        color-mix(in srgb, var(--color-accent, var(--color-ink)) 75%, transparent) 60%,
        color-mix(in srgb, var(--color-accent, var(--color-ink)) 20%, transparent) 92%,
        color-mix(in srgb, var(--color-accent, var(--color-ink)) 0%, transparent) 100%
      );
    }

    /* Catering tile is tall (spans 2 rows) — diagonal mask reveals photo at
       the bottom-right where the eye lands after reading the copy. */
    .wte__card--catering::before {
      background: linear-gradient(
        160deg,
        var(--color-accent, var(--color-ink)) 0%,
        var(--color-accent, var(--color-ink)) 32%,
        color-mix(in srgb, var(--color-accent, var(--color-ink)) 78%, transparent) 58%,
        color-mix(in srgb, var(--color-accent, var(--color-ink)) 25%, transparent) 90%,
        color-mix(in srgb, var(--color-accent, var(--color-ink)) 0%, transparent) 100%
      );
    }
  }

  .wte__card-inner {
    position: relative;
    z-index: 2; /* sits above .wte__card::before (z-index 1) brand-tint mask */
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--sp-5);
    min-height: 260px;
  }

  /* Catering — feature size, more breathing room */
  .wte__card--catering .wte__card-inner {
    min-height: 360px;
    padding: var(--sp-6) var(--sp-6) var(--sp-5);
  }

  @media (min-width: 900px) {
    .wte__card--catering .wte__card-inner {
      padding: var(--sp-7);
    }
  }

  /* Locations — wide horizontal strip on desktop */
  @media (min-width: 900px) {
    .wte__card--locations .wte__card-inner {
      flex-direction: row;
      align-items: center;
      gap: var(--sp-5);
      padding: var(--sp-5) var(--sp-6);
    }
    .wte__card--locations .wte__copy {
      max-width: 56ch;
    }
  }

  .wte__copy {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    max-width: 38ch;
  }

  .wte__eyebrow {
    color: var(--color-accent-contrast);
    opacity: 1;
  }

  .wte__card-heading {
    font-size: var(--fs-500);
    line-height: 1;
    letter-spacing: var(--ls-display-tight);
  }

  .wte__card--catering .wte__card-heading {
    font-size: clamp(var(--fs-500), 4vw, var(--fs-700));
  }

  .wte__body {
    font-size: var(--fs-300);
    line-height: var(--lh-relaxed);
    color: var(--color-accent-contrast);
    max-width: 36ch;
  }

  .wte__cta {
    margin-top: var(--sp-3);
    color: var(--color-accent-contrast);
    font-family: var(--ff-body-stack);
    font-weight: var(--fw-strong);
    font-size: var(--fs-200);
    text-transform: uppercase;
    letter-spacing: var(--ls-caption);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    border-bottom: 2px solid var(--color-accent-contrast);
    padding-bottom: var(--sp-1);
    align-self: flex-start;
    transition: gap var(--dur-fast) var(--ease-out);
  }

  .wte__cta:hover,
  .wte__cta:focus-visible {
    gap: var(--sp-3);
  }
</style>
