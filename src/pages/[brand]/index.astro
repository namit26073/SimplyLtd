---
import { getCollection, getEntry } from "astro:content";
import { Image } from "astro:assets";
import Base from "../../layouts/Base.astro";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (async () => {
  const brands = await getCollection("brands");
  return brands
    .filter((b) => b.data.visible)
    .map((entry) => ({
      params: { brand: entry.data.slug },
      props: { entry },
    }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const brand = entry.data;
const wordmark = brand.name.replace(/^Simply\s+/i, "");

const pitch = brand.primaryPitchSlug
  ? (await getEntry("locations", brand.primaryPitchSlug))?.data ?? null
  : null;

const allBrands = await getCollection("brands");
const otherBrands = allBrands
  .filter((b) => b.data.visible && b.data.slug !== brand.slug)
  .sort((a, b) => a.data.order - b.data.order)
  .map((b) => b.data);

const hoursEntries = pitch
  ? (Object.entries(pitch.openingHours) as [string, string | undefined][]).filter(
      ([, v]) => Boolean(v),
    )
  : [];

const hasVideo = Boolean(brand.behindCounterVideo);
const hasBehindImage = !hasVideo && Boolean(brand.behindCounterImage);

const hasHeroVideo = Boolean(brand.heroVideo);
const hasHeroImage = Boolean(brand.heroImage);
---

<Base title={brand.name} description={brand.tagline} brand={brand.slug}>
  <article class="brand-page">
    {/* Hero ------------------------------------------------------------------
        Cinematic full-bleed treatment per sub-brand. Mirrors the homepage
        Hero pattern: poster image paints first (LCP), video reveals once
        buffered, brand-tinted gradient mask anchors the type column on the
        left while keeping the photo cinematic to the right.

        Falafel + Shawarma use owner-provided kitchen footage as the v1
        heroVideo. Burgers + future AI-gen brand films swap in via the
        `heroVideo` content field; no template change required. */}
    <section class="brand-hero" aria-labelledby="brand-hero-heading">
      <div class="brand-hero__bg" aria-hidden="true">
        {hasHeroImage && brand.heroImage ? (
          <Image
            src={brand.heroImage}
            alt=""
            class="brand-hero__poster"
            widths={[640, 1024, 1440, 1920, 2400]}
            sizes="100vw"
            loading="eager"
            fetchpriority="high"
            quality={78}
          />
        ) : null}
        {hasHeroVideo ? (
          <video
            class="brand-hero__video"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            poster=""
          >
            <source src={brand.heroVideo} type="video/mp4" />
          </video>
        ) : null}
        <div class="brand-hero__mask"></div>
      </div>

      {hasHeroVideo && (
        <button class="brand-hero__media-toggle" type="button" aria-pressed="false">
          <span class="brand-hero__media-toggle-icon brand-hero__media-toggle-icon--pause" aria-hidden="true">
            <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor">
              <rect x="3.5" y="2.5" width="3" height="11" rx="0.6"></rect>
              <rect x="9.5" y="2.5" width="3" height="11" rx="0.6"></rect>
            </svg>
          </span>
          <span class="brand-hero__media-toggle-icon brand-hero__media-toggle-icon--play" aria-hidden="true">
            <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor">
              <path d="M3.5 2.7c0-.6.7-1 1.2-.66l8.6 5.3c.5.3.5 1 0 1.32l-8.6 5.3c-.5.3-1.2 0-1.2-.66Z"></path>
            </svg>
          </span>
          <span class="brand-hero__media-toggle-label">Pause background video</span>
        </button>
      )}

      <div class="brand-hero__content">
        <p class="t-caption brand-hero__concept">Simply</p>
        <h1 id="brand-hero-heading" class="t-display brand-hero__wordmark">{wordmark}</h1>
        <p class="t-editorial t-editorial--italic brand-hero__dek">{brand.introDek}</p>

        <ul role="list" class="brand-hero__meta">
          {pitch && <li class="t-caption">{pitch.name} · {pitch.postcode}</li>}
          <li class="t-caption">{brand.cuisine}</li>
          {brand.dietary?.map((tag) => <li class="t-caption">{tag}</li>)}
        </ul>

        <div class="brand-hero__ctas">
          <a href="/catering/" class="brand-hero__cta brand-hero__cta--primary">
            Hire {brand.name} for your event
            <span aria-hidden="true">→</span>
          </a>
          <a href="/locations/" class="brand-hero__cta brand-hero__cta--secondary">
            Find us
          </a>
        </div>
      </div>
    </section>

    {/* Behind the counter ---------------------------------------------------- */}
    <section class="behind-counter" aria-labelledby="behind-counter-heading">
      <div class="behind-counter__inner">
        <header class="behind-counter__header">
          <p class="t-caption behind-counter__kicker">Behind the counter</p>
          <h2 id="behind-counter-heading" class="t-display behind-counter__heading">
            Everything is prepared on the truck.
          </h2>
        </header>

        <div class="behind-counter__body">
          <figure class="behind-counter__media">
            {
              hasVideo ? (
                <>
                  <video
                    class="behind-counter__video"
                    src={brand.behindCounterVideo}
                    controls
                    muted
                    preload="metadata"
                    playsinline
                    aria-describedby="behind-counter-copy"
                  >
                    Your browser doesn't support inline video. Visit us at the truck instead.
                  </video>
                  <figcaption class="visually-hidden">
                    Silent kitchen B-roll showing prep and service inside the {brand.name} truck.
                    A text description of the kitchen follows.
                  </figcaption>
                </>
              ) : hasBehindImage && brand.behindCounterImage ? (
                <>
                  <Image
                    src={brand.behindCounterImage}
                    alt={brand.behindCounterAlt ?? ""}
                    class="behind-counter__image"
                    widths={[640, 1024, 1440, 1920]}
                    sizes="(min-width: 900px) 60vw, 100vw"
                    loading="lazy"
                    quality={78}
                  />
                  {brand.behindCounterAlt && (
                    <figcaption class="visually-hidden">{brand.behindCounterAlt}</figcaption>
                  )}
                </>
              ) : (
                <div class="behind-counter__media-placeholder" role="img" aria-label={`Placeholder for behind-the-counter still — ${brand.name}`}>
                  <span class="t-caption">Behind the counter</span>
                </div>
              )
            }
          </figure>

          <div class="behind-counter__copy" id="behind-counter-copy">
            <p class="t-body">
              The {wordmark.toLowerCase()} kitchen is small. Two or three people, one prep bench, one
              service window. That's the operating discipline — everything fresh, everything to
              order, everything from the same team that's been doing it since 2019.
            </p>
            <p class="t-body">
              The menu stays small on purpose: a few things, done properly.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* Pitch card ----------------------------------------------------------- */}
    {
      pitch && (
        <section class="pitch" aria-labelledby="pitch-heading">
          <div class="pitch__inner">
            <header class="pitch__header">
              <p class="t-caption pitch__kicker">Find us</p>
              <h2 id="pitch-heading" class="t-display pitch__heading">
                {pitch.name}
              </h2>
            </header>

            <div class="pitch__body">
              <address class="pitch__address t-body">
                {pitch.addressLines.map((line) => <span>{line}</span>)}
                <span class="pitch__postcode">{pitch.postcode}</span>
              </address>

              {hoursEntries.length > 0 && (
                <table class="pitch__hours">
                  <caption class="t-caption pitch__hours-caption">Opening hours</caption>
                  <tbody>
                    {hoursEntries.map(([day, range]) => (
                      <tr>
                        <th scope="row" class="t-caption pitch__hours-day">
                          {day}
                        </th>
                        <td class="t-body">{range}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              )}

              {pitch.notes && <p class="t-body pitch__notes">{pitch.notes}</p>}

              <a href="/locations/" class="pitch__cta">
                See all locations
                <span aria-hidden="true">→</span>
              </a>
            </div>
          </div>
        </section>
      )
    }

    {/* Cross-links ---------------------------------------------------------- */}
    {
      otherBrands.length > 0 && (
        <section class="cross-links" aria-labelledby="cross-links-heading">
          <div class="cross-links__inner">
            <header class="cross-links__header">
              <p class="t-caption">The rest of the fleet</p>
              <h2 id="cross-links-heading" class="t-display cross-links__heading">
                While you're here.
              </h2>
            </header>

            <ul role="list" class="cross-links__grid">
              {otherBrands.map((other) => (
                <li class="cross-links__item" data-brand={other.slug}>
                  <a href={`/${other.slug}/`} class="cross-links__link">
                    <p class="t-caption">Simply</p>
                    <h3 class="t-display cross-links__wordmark">{other.name.replace(/^Simply\s+/i, "")}</h3>
                    <p class="t-editorial t-editorial--italic cross-links__dek">{other.tagline}</p>
                    <span class="cross-links__arrow" aria-hidden="true">
                      Visit →
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </section>
      )
    }
  </article>
</Base>

<style>
  /* ---------- Brand hero (cinematic full-bleed) ---------- */
  .brand-hero {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    /* Solid brand ground so the section never flashes before paint */
    background: var(--color-accent);
    color: var(--color-accent-contrast);
    min-height: 78vh;
    display: flex;
    align-items: flex-end;
  }

  @media (min-width: 900px) {
    .brand-hero {
      min-height: 86vh;
      align-items: center;
    }
  }

  .brand-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .brand-hero__poster,
  .brand-hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  .brand-hero__poster { z-index: 0; }

  .brand-hero__video {
    z-index: 1;
    opacity: 0;
    transition: opacity var(--dur-slow) var(--ease-out);
  }
  .brand-hero__video[data-ready] { opacity: 1; }

  /* Brand-tinted gradient mask. Mobile: vertical, brand-colour bottoms out
     at solid accent under the type. Desktop: diagonal, brand-colour solid
     across the left ~45% (type column), photo unobstructed to the right.
     Mask must fully cover the photo under text — shawarma (yellow + ink
     text) and falafel (green + cream text) both failed AA when the bottom
     stop held at 92% accent and video frames bled through. */
  .brand-hero__mask {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--color-accent) 25%, transparent) 0%,
        color-mix(in srgb, var(--color-accent) 50%, transparent) 38%,
        color-mix(in srgb, var(--color-accent) 92%, transparent) 65%,
        var(--color-accent) 100%
      );
  }

  @media (min-width: 900px) {
    .brand-hero__mask {
      background:
        linear-gradient(
          100deg,
          var(--color-accent) 0%,
          color-mix(in srgb, var(--color-accent) 92%, transparent) 42%,
          color-mix(in srgb, var(--color-accent) 30%, transparent) 72%,
          color-mix(in srgb, var(--color-accent) 0%, transparent) 100%
        );
    }
  }

  .brand-hero__content {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: var(--page-max);
    margin: 0 auto;
    padding: var(--sp-7) var(--page-gutter) var(--sp-6);
  }

  @media (min-width: 900px) {
    .brand-hero__content {
      padding: var(--sp-7) var(--page-gutter);
    }
    .brand-hero__content > *:not(.brand-hero__ctas) {
      max-width: 32rem;
    }
  }

  .brand-hero__concept {
    color: var(--color-accent-contrast);
    margin-bottom: var(--sp-1);
  }

  .brand-hero__wordmark {
    font-size: clamp(var(--fs-800), 18vw, var(--fs-900));
    line-height: 0.86;
    letter-spacing: var(--ls-display-tight);
    margin-bottom: var(--sp-4);
    text-transform: uppercase;
    color: var(--color-accent-contrast);
  }

  .brand-hero__dek {
    font-size: clamp(var(--fs-400), 2.6vw, var(--fs-500));
    max-width: 38ch;
    color: var(--color-accent-contrast);
  }

  .brand-hero__meta {
    margin-top: var(--sp-4);
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  .brand-hero__meta li {
    padding: var(--sp-1) var(--sp-3);
    border: 1px solid color-mix(in srgb, currentColor 55%, transparent);
    border-radius: var(--r-pill);
  }

  .brand-hero__ctas {
    margin-top: var(--sp-5);
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
  }

  .brand-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-3) var(--sp-4);
    font-family: var(--ff-body-stack);
    font-weight: var(--fw-strong);
    font-size: var(--fs-200);
    text-transform: uppercase;
    letter-spacing: var(--ls-caption);
    text-decoration: none;
    border-radius: var(--r-pill);
    transition: transform var(--dur-fast) var(--ease-out);
  }

  .brand-hero__cta--primary {
    background: var(--color-accent-contrast);
    color: var(--color-accent);
  }

  .brand-hero__cta--secondary {
    background: transparent;
    color: var(--color-accent-contrast);
    border: 1.5px solid var(--color-accent-contrast);
  }

  .brand-hero__cta:hover,
  .brand-hero__cta:focus-visible {
    transform: translateY(-1px);
  }

  .brand-hero :focus-visible {
    outline: 2px solid var(--color-accent-contrast);
    outline-offset: 3px;
  }

  /* WCAG 2.2.2 — pause/play control for the autoplaying brand hero video.
     Same pattern as the homepage Hero; tinted to read on the brand ground. */
  .brand-hero__media-toggle {
    position: absolute;
    top: var(--sp-4);
    right: var(--sp-4);
    z-index: 4;
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-3);
    background: color-mix(in srgb, var(--color-ink) 70%, transparent);
    color: var(--color-cream);
    border: 1px solid color-mix(in srgb, var(--color-cream) 35%, transparent);
    border-radius: var(--r-pill);
    font-family: var(--ff-body-stack);
    font-weight: var(--fw-strong);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: var(--ls-caption);
    cursor: pointer;
    transition: background var(--dur-fast) var(--ease-out),
                border-color var(--dur-fast) var(--ease-out);
  }
  .brand-hero__media-toggle:hover,
  .brand-hero__media-toggle:focus-visible {
    background: color-mix(in srgb, var(--color-ink) 85%, transparent);
    border-color: var(--color-cream);
  }
  .brand-hero__media-toggle-icon {
    display: inline-flex;
    line-height: 0;
  }
  .brand-hero__media-toggle .brand-hero__media-toggle-icon--play { display: none; }
  .brand-hero__media-toggle[aria-pressed="true"] .brand-hero__media-toggle-icon--pause { display: none; }
  .brand-hero__media-toggle[aria-pressed="true"] .brand-hero__media-toggle-icon--play { display: inline-flex; }

  @media (max-width: 559px) {
    .brand-hero__media-toggle-label {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
    .brand-hero__media-toggle {
      padding: var(--sp-2);
    }
  }

  /* Reduced motion: hide the autoplaying video and its control — poster
     persists as the permanent still. */
  @media (prefers-reduced-motion: reduce) {
    .brand-hero__video { display: none; }
    .brand-hero__media-toggle { display: none; }
  }

  /* ---------- Behind the counter ---------- */
  .behind-counter {
    padding: var(--sp-7) var(--page-gutter);
    background: var(--color-cream);
  }

  .behind-counter__inner {
    max-width: var(--page-max);
    margin: 0 auto;
  }

  .behind-counter__header {
    margin-bottom: var(--sp-5);
    max-width: var(--measure-prose);
  }

  .behind-counter__kicker {
    color: var(--color-text-muted);
    margin-bottom: var(--sp-2);
  }

  .behind-counter__heading {
    font-size: clamp(var(--fs-600), 5vw, var(--fs-700));
    line-height: 1;
  }

  .behind-counter__body {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-5);
    align-items: start;
  }

  @media (min-width: 900px) {
    .behind-counter__body {
      grid-template-columns: 1.2fr 1fr;
      gap: var(--sp-6);
    }
  }

  .behind-counter__media {
    aspect-ratio: 4 / 5;
    background: var(--color-paper);
    border-radius: var(--r-lg);
    overflow: hidden;
    display: grid;
    place-items: center;
    margin: 0;
  }

  .behind-counter__video,
  .behind-counter__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Brand-tinted placeholder so the slot reads as part of the brand identity
     rather than a void. Renders denser hatch + brand-mix ground. */
  .behind-counter__media-placeholder {
    color: var(--color-accent);
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--color-accent) 22%, transparent) 0,
        color-mix(in srgb, var(--color-accent) 22%, transparent) 14px,
        transparent 14px,
        transparent 32px
      ),
      color-mix(in srgb, var(--color-accent, var(--color-canal)) 10%, var(--color-paper));
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
  }

  .behind-counter__media-placeholder .t-caption {
    background: var(--color-accent);
    color: var(--color-accent-contrast);
    padding: var(--sp-2) var(--sp-4);
    border-radius: var(--r-pill);
    font-size: var(--fs-200);
  }

  /* .visually-hidden lives globally in src/styles/reset.css */

  .behind-counter__copy {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .behind-counter__copy p {
    font-size: var(--fs-300);
    line-height: var(--lh-relaxed);
  }

  /* ---------- Pitch card ---------- */
  .pitch {
    padding: var(--sp-7) var(--page-gutter);
    background: var(--color-paper);
    border-top: 1px solid var(--color-line);
  }

  .pitch__inner {
    max-width: var(--page-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-5);
  }

  @media (min-width: 720px) {
    .pitch__inner {
      grid-template-columns: 1fr 2fr;
      gap: var(--sp-7);
    }
  }

  .pitch__kicker {
    color: var(--color-text-muted);
    margin-bottom: var(--sp-2);
  }

  .pitch__heading {
    font-size: clamp(var(--fs-600), 5vw, var(--fs-700));
    line-height: 1;
  }

  .pitch__body {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .pitch__address {
    font-style: normal;
    font-size: var(--fs-400);
    line-height: var(--lh-snug);
  }

  .pitch__address span {
    display: block;
  }

  .pitch__postcode {
    font-family: var(--ff-display-stack);
    text-transform: uppercase;
    font-size: var(--fs-500);
    margin-top: var(--sp-1);
  }

  .pitch__hours {
    border-collapse: collapse;
    text-align: left;
  }

  .pitch__hours-caption {
    text-align: left;
    color: var(--color-text-muted);
    margin-bottom: var(--sp-2);
  }

  .pitch__hours-day {
    padding-right: var(--sp-4);
    padding-block: var(--sp-1);
    color: var(--color-text-muted);
    font-weight: var(--fw-strong);
    text-transform: capitalize;
  }

  .pitch__hours td {
    padding-block: var(--sp-1);
  }

  .pitch__notes {
    color: var(--color-text-muted);
    font-size: var(--fs-200);
    max-width: 40ch;
  }

  .pitch__cta {
    align-self: flex-start;
    color: var(--color-ink);
    font-family: var(--ff-body-stack);
    font-weight: var(--fw-strong);
    font-size: var(--fs-200);
    text-transform: uppercase;
    letter-spacing: var(--ls-caption);
    text-decoration: none;
    border-bottom: 2px solid var(--color-ink);
    padding-bottom: var(--sp-1);
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    transition: gap var(--dur-fast) var(--ease-out);
  }

  .pitch__cta:hover,
  .pitch__cta:focus-visible {
    gap: var(--sp-3);
  }

  /* ---------- Cross-links ---------- */
  .cross-links {
    padding: var(--sp-7) var(--page-gutter);
    background: var(--color-cream);
    border-top: 1px solid var(--color-line);
  }

  .cross-links__inner {
    max-width: var(--page-max);
    margin: 0 auto;
  }

  .cross-links__header {
    margin-bottom: var(--sp-5);
  }

  .cross-links__heading {
    font-size: clamp(var(--fs-600), 5vw, var(--fs-700));
    line-height: 1;
    margin-top: var(--sp-2);
  }

  .cross-links__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-3);
  }

  @media (min-width: 720px) {
    .cross-links__grid {
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }
  }

  .cross-links__item {
    background: var(--color-accent);
    color: var(--color-accent-contrast);
    border-radius: var(--r-lg);
    overflow: hidden;
    transition: transform var(--dur-base) var(--ease-out);
  }

  .cross-links__item:has(.cross-links__link:hover),
  .cross-links__item:has(.cross-links__link:focus-visible) {
    transform: translateY(-3px);
  }

  .cross-links__link {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    padding: var(--sp-4);
    text-decoration: none;
    color: inherit;
    min-height: 220px;
  }

  .cross-links__link :focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }

  .cross-links__wordmark {
    font-size: var(--fs-700);
    line-height: 0.92;
    text-transform: uppercase;
  }

  .cross-links__dek {
    font-size: var(--fs-300);
    color: var(--color-accent-contrast);
    margin-top: var(--sp-1);
  }

  .cross-links__arrow {
    margin-top: auto;
    font-family: var(--ff-body-stack);
    font-weight: var(--fw-strong);
    font-size: var(--fs-200);
    text-transform: uppercase;
    letter-spacing: var(--ls-caption);
    padding-top: var(--sp-3);
  }
</style>

<script>
  // Brand hero — reveal video once it has enough buffered to paint a
  // frame; wire the WCAG 2.2.2 pause/play control.
  const video = document.querySelector(".brand-hero__video");
  if (video instanceof HTMLVideoElement) {
    const ready = () => video.setAttribute("data-ready", "");
    if (video.readyState >= 2) {
      ready();
    } else {
      video.addEventListener("loadeddata", ready, { once: true });
      video.addEventListener("playing", ready, { once: true });
    }
  }

  const toggle = document.querySelector(".brand-hero__media-toggle");
  const label = document.querySelector(".brand-hero__media-toggle-label");
  if (
    toggle instanceof HTMLButtonElement &&
    video instanceof HTMLVideoElement &&
    label instanceof HTMLElement
  ) {
    const sync = () => {
      const paused = video.paused;
      toggle.setAttribute("aria-pressed", paused ? "true" : "false");
      label.textContent = paused ? "Play background video" : "Pause background video";
    };
    toggle.addEventListener("click", () => {
      if (video.paused) {
        void video.play();
      } else {
        video.pause();
      }
      sync();
    });
    video.addEventListener("play", sync);
    video.addEventListener("pause", sync);
    sync();
  }
</script>
