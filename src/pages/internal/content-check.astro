---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const allBrands = await getCollection("brands");
const visibleBrands = allBrands.filter((b) => b.data.visible).sort((a, b) => a.data.order - b.data.order);
const hiddenBrands = allBrands.filter((b) => !b.data.visible);
const locations = await getCollection("locations");
---

<Base title="Content check" noindex bare>
  <main style="padding: var(--sp-7) var(--page-gutter); max-width: var(--page-max); margin: 0 auto;">
    <p class="t-caption" style="color: var(--color-text-muted);">Internal · Slice 3 verification</p>
    <h1 class="t-display" style="font-size: var(--fs-700); margin-top: var(--sp-2);">
      Content collections
    </h1>

    <section style="margin-top: var(--sp-6);">
      <h2 class="t-display" style="font-size: var(--fs-500);">Visible brands ({visibleBrands.length})</h2>
      <ul role="list" style="margin-top: var(--sp-3); display: grid; gap: var(--sp-3);">
        {
          visibleBrands.map((b) => (
            <li
              data-brand={b.data.slug}
              style="background: var(--color-accent); color: var(--color-accent-contrast); padding: var(--sp-3); border-radius: var(--r-md);"
            >
              <p class="t-display" style="font-size: var(--fs-500);">
                {b.data.name}
              </p>
              <p class="t-editorial t-editorial--italic" style="margin-top: var(--sp-2);">
                {b.data.tagline}
              </p>
              <p class="t-caption" style="margin-top: var(--sp-2);">
                {b.data.cuisine} · pitch: {b.data.primaryPitchSlug ?? "—"}
              </p>
            </li>
          ))
        }
      </ul>
    </section>

    <section style="margin-top: var(--sp-6);">
      <h2 class="t-display" style="font-size: var(--fs-500);">Hidden brands ({hiddenBrands.length})</h2>
      <ul role="list" style="margin-top: var(--sp-3); display: flex; gap: var(--sp-2); flex-wrap: wrap;">
        {
          hiddenBrands.map((b) => (
            <li class="t-caption" style="padding: var(--sp-1) var(--sp-3); border: 1px solid var(--color-line); border-radius: var(--r-pill);">
              {b.data.name} · visible:false
            </li>
          ))
        }
      </ul>
    </section>

    <section style="margin-top: var(--sp-6);">
      <h2 class="t-display" style="font-size: var(--fs-500);">Locations ({locations.length})</h2>
      <ul role="list" style="margin-top: var(--sp-3); display: grid; gap: var(--sp-3);">
        {
          locations.map((l) => (
            <li style="padding: var(--sp-3); border: 1px solid var(--color-line); border-radius: var(--r-md);">
              <p class="t-display" style="font-size: var(--fs-400);">
                {l.data.name}
              </p>
              <p class="t-body" style="margin-top: var(--sp-1);">
                {l.data.addressLines.join(", ")} · {l.data.postcode}
              </p>
              <p class="t-caption" style="margin-top: var(--sp-1); color: var(--color-text-muted);">
                Brands on pitch: {l.data.brandsOnPitch.join(", ")}
              </p>
            </li>
          ))
        }
      </ul>
    </section>
  </main>
</Base>
