---
import Base from "../layouts/Base.astro";
import Franchising from "../islands/forms/Franchising.tsx";
---

<Base
  title="Franchising"
  description="Run a Simply truck of your own — three proven concepts, one operating model, six years of pitch-tested experience to work from. Apply to franchise Simply Ltd."
>
  <article class="franchising-page">
    {/* Hero ----------------------------------------------------------------- */}
    <section class="franchise-hero" aria-labelledby="franchise-hero-heading">
      <div class="franchise-hero__inner">
        <div class="franchise-hero__copy">
          <p class="t-caption franchise-hero__kicker">Franchising</p>
          <h1 id="franchise-hero-heading" class="t-display franchise-hero__heading">
            Run a Simply truck <br />of your own.
          </h1>
          <p class="t-editorial t-editorial--italic franchise-hero__dek">
            Three proven concepts. One operating model. Six years of pitch-tested street-food
            experience to work from. We're looking for partners who like a queue.
          </p>
          <a href="#enquire" class="franchise-hero__cta">
            Apply below
            <span aria-hidden="true">↓</span>
          </a>
        </div>
        <div class="franchise-hero__art" aria-hidden="true">
          <span class="franchise-hero__shape franchise-hero__shape--main"></span>
          <span class="franchise-hero__shape franchise-hero__shape--accent"></span>
        </div>
      </div>
    </section>

    {/* Track record --------------------------------------------------------- */}
    <section class="track" aria-labelledby="track-heading">
      <div class="track__inner">
        <header class="track__header">
          <p class="t-caption">Track record</p>
          <h2 id="track-heading" class="t-display track__heading">A proven model.</h2>
        </header>

        <div class="track__stats">
          <div class="stat">
            <p class="t-display stat__figure">2019</p>
            <p class="t-caption stat__label">Founded</p>
          </div>
          <div class="stat">
            <p class="t-display stat__figure">3</p>
            <p class="t-caption stat__label">Trucks operating</p>
          </div>
          <div class="stat">
            <p class="t-display stat__figure">5</p>
            <p class="t-caption stat__label">Sub-brand concepts</p>
          </div>
          <div class="stat">
            <p class="t-display stat__figure">~250m</p>
            <p class="t-caption stat__label">Between pitches</p>
          </div>
        </div>
      </div>
    </section>

    {/* What you get --------------------------------------------------------- */}
    <section class="provisions" aria-labelledby="provisions-heading">
      <div class="provisions__inner">
        <header class="provisions__header">
          <p class="t-caption">What we provide</p>
          <h2 id="provisions-heading" class="t-display provisions__heading">
            The map, not just the keys.
          </h2>
        </header>

        <ol role="list" class="provisions__list">
          <li class="provision">
            <p class="t-display provision__numeral" aria-hidden="true">01</p>
            <h3 class="t-display provision__title">Operations training</h3>
            <p class="t-body provision__body">
              How we run the trucks every day — service standards, safety, prep flow, supplier
              relationships. Hands-on, on our pitches.
            </p>
          </li>
          <li class="provision">
            <p class="t-display provision__numeral" aria-hidden="true">02</p>
            <h3 class="t-display provision__title">The recipes</h3>
            <p class="t-body provision__body">
              Full access to our marinades, sauces, smash technique, dough work. The same standards
              every truck holds itself to.
            </p>
          </li>
          <li class="provision">
            <p class="t-display provision__numeral" aria-hidden="true">03</p>
            <h3 class="t-display provision__title">Supply chain</h3>
            <p class="t-body provision__body">
              Our supplier relationships — produce, meat, packaging — so you start at our
              wholesale prices, not retail.
            </p>
          </li>
          <li class="provision">
            <p class="t-display provision__numeral" aria-hidden="true">04</p>
            <h3 class="t-display provision__title">Brand</h3>
            <p class="t-body provision__body">
              The Simply name, marketing assets, social presence. Customers find you because they
              already know us.
            </p>
          </li>
        </ol>
      </div>
    </section>

    {/* Who we're looking for ------------------------------------------------ */}
    <section class="ideal" aria-labelledby="ideal-heading">
      <div class="ideal__inner">
        <header class="ideal__header">
          <p class="t-caption">Ideal partner</p>
          <h2 id="ideal-heading" class="t-display ideal__heading">Who we're looking for.</h2>
        </header>

        <div class="ideal__grid">
          <div class="ideal-card">
            <h3 class="t-display ideal-card__title">Passion for food</h3>
            <p class="t-body ideal-card__body">
              You taste your way through hard decisions. You understand that "good enough"
              ingredients add up to "good enough" food, and that isn't the goal.
            </p>
          </div>
          <div class="ideal-card">
            <h3 class="t-display ideal-card__title">Hustle</h3>
            <p class="t-body ideal-card__body">
              Food trucks are early starts and long days. You like being on the floor, on the grill,
              in the queue. The truck is your business, not a side project.
            </p>
          </div>
          <div class="ideal-card">
            <h3 class="t-display ideal-card__title">Community focus</h3>
            <p class="t-body ideal-card__body">
              The queue is a relationship. You remember the regulars, you fix problems before
              they're complaints, you build the kind of pitch people walk past and stop at.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* Process -------------------------------------------------------------- */}
    <section class="franchise-process" aria-labelledby="franchise-process-heading">
      <div class="franchise-process__inner">
        <header class="franchise-process__header">
          <p class="t-caption">How it works</p>
          <h2 id="franchise-process-heading" class="t-display franchise-process__heading">
            From enquiry to opening.
          </h2>
        </header>

        <ol role="list" class="franchise-process__steps">
          <li class="step">
            <p class="t-display step__index" aria-hidden="true">1</p>
            <h3 class="t-display step__title">Submit the form below</h3>
            <p class="t-body step__body">
              Region, timeline, investment range, your background. The more we know, the better
              the first call.
            </p>
          </li>
          <li class="step">
            <p class="t-display step__index" aria-hidden="true">2</p>
            <h3 class="t-display step__title">Discovery call</h3>
            <p class="t-body step__body">
              30–45 minutes. We hear your story; you hear ours. We agree on whether to move to a
              full prospectus.
            </p>
          </li>
          <li class="step">
            <p class="t-display step__index" aria-hidden="true">3</p>
            <h3 class="t-display step__title">Full prospectus + financials</h3>
            <p class="t-body step__body">
              Detailed numbers, territory specifics, training plan, support model. You take it
              away, we give you references to call.
            </p>
          </li>
          <li class="step">
            <p class="t-display step__index" aria-hidden="true">4</p>
            <h3 class="t-display step__title">Sign and train</h3>
            <p class="t-body step__body">
              Franchise agreement, on-pitch training, your truck build, soft launch, then full
              service.
            </p>
          </li>
        </ol>
      </div>
    </section>

    {/* Form ----------------------------------------------------------------- */}
    <section id="enquire" class="enquire" aria-labelledby="enquire-heading">
      <div class="enquire__inner">
        <header class="enquire__header">
          <p class="t-caption">Apply</p>
          <h2 id="enquire-heading" class="t-display enquire__heading">
            Tell us about you.
          </h2>
          <p class="t-editorial t-editorial--italic enquire__dek">
            We review franchising enquiries on Friday afternoons. Expect a reply within five
            working days — we start with a discovery call before any paperwork.
          </p>
        </header>

        <Franchising client:visible />
      </div>
    </section>
  </article>
</Base>

<style>
  /* Hero (mirrors catering-hero) */
  .franchise-hero {
    padding: var(--sp-6) var(--page-gutter) var(--sp-7);
    background: var(--color-ink);
    color: var(--color-cream);
    overflow: hidden;
  }
  .franchise-hero__inner {
    max-width: var(--page-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-5);
    align-items: center;
    position: relative;
  }
  @media (min-width: 900px) {
    .franchise-hero__inner {
      grid-template-columns: 1.15fr 1fr;
      gap: var(--sp-6);
      min-height: 58vh;
    }
  }
  .franchise-hero__copy {
    position: relative;
    z-index: 1;
  }
  .franchise-hero__kicker {
    color: color-mix(in srgb, var(--color-cream) 60%, transparent);
    margin-bottom: var(--sp-3);
  }
  .franchise-hero__heading {
    font-size: clamp(var(--fs-700), 9vw, var(--fs-800));
    line-height: 0.92;
    letter-spacing: var(--ls-display-tight);
  }
  .franchise-hero__dek {
    margin-top: var(--sp-4);
    font-size: var(--fs-400);
    max-width: 38ch;
    color: color-mix(in srgb, var(--color-cream) 85%, transparent);
  }
  .franchise-hero__cta {
    margin-top: var(--sp-5);
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-3) var(--sp-4);
    background: var(--color-cream);
    color: var(--color-ink);
    font-family: var(--ff-body-stack);
    font-weight: var(--fw-strong);
    font-size: var(--fs-200);
    text-transform: uppercase;
    letter-spacing: var(--ls-caption);
    text-decoration: none;
    border-radius: var(--r-pill);
    transition: transform var(--dur-fast) var(--ease-out);
  }
  .franchise-hero__cta:hover,
  .franchise-hero__cta:focus-visible { transform: translateY(-1px); }
  .franchise-hero :focus-visible {
    outline: 2px solid var(--color-cream);
    outline-offset: 3px;
  }
  /* Cutout zone — hidden on mobile; revealed on desktop. Swap for <Image />
     when asset lands. */
  .franchise-hero__art {
    display: none;
  }
  @media (min-width: 900px) {
    .franchise-hero__art {
      display: block;
      position: relative;
      height: 100%;
    }
  }
  .franchise-hero__shape {
    position: absolute;
    display: block;
    pointer-events: none;
    border-radius: 50%;
  }
  .franchise-hero__shape--main {
    width: clamp(280px, 56vw, 540px);
    aspect-ratio: 1;
    right: -10%;
    top: 50%;
    transform: translateY(-50%);
    background:
      radial-gradient(
        ellipse at 45% 45%,
        color-mix(in srgb, #e8b83a 22%, transparent) 0%,
        color-mix(in srgb, #e8b83a 12%, transparent) 50%,
        transparent 75%
      );
  }
  .franchise-hero__shape--accent {
    width: clamp(110px, 22vw, 200px);
    aspect-ratio: 1;
    right: 36%;
    bottom: 10%;
    background:
      radial-gradient(
        ellipse at 50% 50%,
        color-mix(in srgb, #c03020 26%, transparent) 0%,
        color-mix(in srgb, #c03020 14%, transparent) 50%,
        transparent 75%
      );
  }

  /* Shared frame */
  .track, .provisions, .ideal, .franchise-process, .enquire {
    padding: var(--sp-7) var(--page-gutter);
    border-top: 1px solid var(--color-line);
  }
  .track { background: var(--color-cream); }
  .provisions { background: var(--color-paper); }
  .ideal { background: var(--color-cream); }
  .franchise-process { background: var(--color-paper); }
  .enquire { background: var(--color-cream); }
  .track__inner, .provisions__inner, .ideal__inner, .franchise-process__inner, .enquire__inner {
    max-width: var(--page-max);
    margin: 0 auto;
  }
  .track__header, .provisions__header, .ideal__header, .franchise-process__header, .enquire__header {
    margin-bottom: var(--sp-5);
  }
  .track__heading, .provisions__heading, .ideal__heading, .franchise-process__heading, .enquire__heading {
    font-size: clamp(var(--fs-600), 6vw, var(--fs-700));
    line-height: 1;
    margin-top: var(--sp-2);
  }

  /* Stats */
  .track__stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-3);
  }
  @media (min-width: 720px) {
    .track__stats { grid-template-columns: repeat(4, 1fr); }
  }
  .stat {
    padding: var(--sp-4);
    background: var(--color-paper);
    border-radius: var(--r-md);
  }
  .stat__figure {
    font-size: clamp(var(--fs-700), 6vw, var(--fs-800));
    line-height: 1;
  }
  .stat__label {
    color: var(--color-text-muted);
    margin-top: var(--sp-1);
  }

  /* Provisions */
  .provisions__list {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-4);
  }
  @media (min-width: 720px) {
    .provisions__list { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1080px) {
    .provisions__list { grid-template-columns: repeat(4, 1fr); }
  }
  .provision {
    padding: var(--sp-4);
    background: var(--color-cream);
    border-radius: var(--r-md);
  }
  .provision__numeral {
    font-size: var(--fs-700);
    line-height: 1;
    color: var(--color-text-muted);
  }
  .provision__title {
    font-size: var(--fs-500);
    margin-top: var(--sp-2);
    line-height: 1;
  }
  .provision__body {
    margin-top: var(--sp-2);
    font-size: var(--fs-300);
    line-height: var(--lh-relaxed);
  }

  /* Ideal cards */
  .ideal__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-3);
  }
  @media (min-width: 720px) {
    .ideal__grid { grid-template-columns: repeat(3, 1fr); }
  }
  .ideal-card {
    padding: var(--sp-5);
    background: var(--color-paper);
    border-radius: var(--r-md);
    border-left: 4px solid var(--color-ink);
  }
  .ideal-card__title {
    font-size: var(--fs-500);
    line-height: 1;
  }
  .ideal-card__body {
    margin-top: var(--sp-2);
    font-size: var(--fs-300);
    line-height: var(--lh-relaxed);
  }

  /* Process steps */
  .franchise-process__steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-4);
  }
  @media (min-width: 720px) {
    .franchise-process__steps { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1080px) {
    .franchise-process__steps { grid-template-columns: repeat(4, 1fr); }
  }
  .step {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .step__index {
    font-size: var(--fs-800);
    line-height: 1;
    color: var(--color-text-muted);
  }
  .step__title {
    font-size: var(--fs-500);
    line-height: 1;
  }
  .step__body {
    font-size: var(--fs-300);
    line-height: var(--lh-relaxed);
  }

  .enquire__dek {
    margin-top: var(--sp-3);
    max-width: 56ch;
    color: color-mix(in srgb, var(--color-ink) 80%, transparent);
  }
</style>
