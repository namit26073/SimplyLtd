{
  "name": "simply-ltd",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Simply Ltd — UK food-truck group marketing site. Astro 6 on Cloudflare Pages.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "npm run build && wrangler dev",
    "check": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "precommit": "npm run lint:fix && npm run format && npm run check",
    "generate-types": "wrangler types",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.5",
    "@types/leaflet": "^1.9.21",
    "astro": "^6.3.3",
    "leaflet": "^1.9.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^4.20260517.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-astro": "^1.3.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "prettier": "^3.4.0",
    "prettier-plugin-astro": "^0.14.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.6",
    "wrangler": "^4.93.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "vite": "^7"
  }
}
