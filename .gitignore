# Dependencies
node_modules/
.pnp/
.pnp.js

# Build output (final stack TBD; cover common possibilities)
dist/
build/
.next/
.nuxt/
.svelte-kit/
.astro/
.vercel/
.netlify/
.wrangler/
.cloudflare/
.cache/

# Environment
.env
.env.local
.env.*.local

# Editor / OS
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Lockfiles — keep one, the agent picks
# (we don't ignore lockfiles; first commit of the chosen one becomes canon)

# Test output
coverage/
.nyc_output/
.vitest-cache/

# Agent / MCP scratch
.playwright-mcp/
.chrome-devtools-mcp/

# Design-review screenshot artefacts (local-only; regenerated each pass)
.audit/

# Curation candidate thumbnails (local reference for asset picking; not
# shipped, large, and re-creatable by re-running the content-researcher pass)
assets-inbox/candidates/

# Raw / intermediate video files staged for processing (the build pipeline
# expects re-encoded outputs in public/videos/; raw sources stay local)
assets-inbox/videos/

# Stray temp screenshots
/temp-*.png

# Asset processing intermediates (full-res source assets stay in assets-inbox/,
# build pipeline outputs go to dist/ which is already ignored)
*.psd
*.ai
*.sketch

.dev.vars*
!.dev.vars.example
!.env.example

# Build-time generated content (Instagram grid fetch output)
src/_generated/
